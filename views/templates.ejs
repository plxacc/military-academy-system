<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>إدارة الرسائل | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col bg-[#05070a] selection:bg-indigo-500 selection:text-white font-sans">
    <%- include('partials/navbar') %>

    <main class="max-w-[90rem] mx-auto px-6 py-12 flex-1 w-full">
        
        <div class="relative rounded-[2.5rem] bg-[#0d1117] border border-[#1f2630] p-10 md:p-12 mb-12 shadow-2xl overflow-hidden">
            <div class="absolute top-0 left-0 w-1/3 h-full bg-gradient-to-r from-indigo-900/20 to-transparent opacity-50"></div>
            <div class="relative z-10">
                <span class="inline-block bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 text-xs font-mono font-bold px-4 py-1.5 rounded-full uppercase tracking-widest mb-4">
                    AUTOMATED COMM SYSTEM
                </span>
                <h2 class="text-3xl md:text-4xl font-black text-white mb-2 tracking-wide">نظام المراسلات التلقائية المباشرة (DM)</h2>
                <p class="text-sm text-gray-400 max-w-2xl leading-relaxed">
                    إدارة قوالب الرسائل وإرسال الإشعارات المباشرة للمتقدمين عبر البوت الخاص بالكلية لكل مرحلة من مراحل القبول.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- القسم 1: المقابلات -->
            <div class="bg-[#0a0d12] border border-[#1f2630] rounded-3xl p-6 flex flex-col shadow-lg relative overflow-hidden">
                <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-l from-orange-500 to-transparent"></div>
                <h3 class="text-xl font-black text-white mb-1 flex items-center gap-2"><span>🎙️</span> رسائل المقابلات</h3>
                <p class="text-xs text-gray-500 mb-4 font-mono">المرشحين لإجراء المقابلة الشخصية</p>
                
                <textarea id="msg-interview" class="w-full h-32 bg-[#0d1117] border border-[#222b38] rounded-xl p-3 text-sm text-gray-300 font-mono resize-none focus:border-orange-500/50 outline-none mb-3" placeholder="اكتب رسالة استدعاء المقابلة هنا..."><%= templates.interview %></textarea>
                <button onclick="saveTemp('interview')" class="btn bg-[#161b22] hover:bg-[#1f2630] border border-[#222b38] text-gray-300 w-full !py-2 mb-6">💾 حفظ كقالب افتراضي</button>

                <div class="flex-1 bg-[#05070a] rounded-xl border border-[#1f2630] p-4 mb-4 overflow-y-auto max-h-48">
                    <h4 class="text-xs font-bold text-gray-400 mb-3 border-b border-[#1f2630] pb-2">القائمة المستهدفة (<%= interviewUsers.length %>):</h4>
                    <% if(interviewUsers.length === 0) { %>
                        <p class="text-xs text-gray-600 text-center mt-4">لا يوجد مرشحين حالياً.</p>
                    <% } else { %>
                        <div class="flex flex-col gap-2">
                            <% interviewUsers.forEach(u => { %>
                                <div class="text-[10px] font-mono text-gray-300 bg-[#0d1117] p-2 rounded-lg border border-[#1f2630] flex justify-between">
                                    <span class="font-bold truncate"><%= u.name %></span>
                                    <span class="text-orange-400">ID: <%= u.copyId %></span>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
                
                <button onclick="sendBulk('interview', interviewIds)" class="btn !bg-orange-600 hover:!bg-orange-500 w-full !py-3 shadow-[0_0_15px_rgba(249,115,22,0.3)]">🚀 إرسال الرسالة للجميع</button>
            </div>

            <!-- القسم 2: القبول المبدئي -->
            <div class="bg-[#0a0d12] border border-[#1f2630] rounded-3xl p-6 flex flex-col shadow-lg relative overflow-hidden">
                <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-l from-emerald-500 to-transparent"></div>
                <h3 class="text-xl font-black text-white mb-1 flex items-center gap-2"><span>🛡️</span> رسائل الميدان</h3>
                <p class="text-xs text-gray-500 mb-4 font-mono">المقبولين مبدئياً لتدريب الميدان</p>
                
                <textarea id="msg-preliminary" class="w-full h-32 bg-[#0d1117] border border-[#222b38] rounded-xl p-3 text-sm text-gray-300 font-mono resize-none focus:border-emerald-500/50 outline-none mb-3" placeholder="اكتب رسالة القبول المبدئي هنا..."><%= templates.preliminary %></textarea>
                <button onclick="saveTemp('preliminary')" class="btn bg-[#161b22] hover:bg-[#1f2630] border border-[#222b38] text-gray-300 w-full !py-2 mb-6">💾 حفظ كقالب افتراضي</button>

                <div class="flex-1 bg-[#05070a] rounded-xl border border-[#1f2630] p-4 mb-4 overflow-y-auto max-h-48">
                    <h4 class="text-xs font-bold text-gray-400 mb-3 border-b border-[#1f2630] pb-2">القائمة المستهدفة (<%= prelimUsers.length %>):</h4>
                    <% if(prelimUsers.length === 0) { %>
                        <p class="text-xs text-gray-600 text-center mt-4">لا يوجد متدربين حالياً.</p>
                    <% } else { %>
                        <div class="flex flex-col gap-2">
                            <% prelimUsers.forEach(u => { %>
                                <div class="text-[10px] font-mono text-gray-300 bg-[#0d1117] p-2 rounded-lg border border-[#1f2630] flex justify-between">
                                    <span class="font-bold truncate"><%= u.name %></span>
                                    <span class="text-emerald-400">ID: <%= u.copyId %></span>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
                
                <button onclick="sendBulk('preliminary', prelimIds)" class="btn !bg-emerald-600 hover:!bg-emerald-500 w-full !py-3 shadow-[0_0_15px_rgba(16,185,129,0.3)]">🚀 إرسال الرسالة للجميع</button>
            </div>

            <!-- القسم 3: الاعتماد النهائي -->
            <div class="bg-[#0a0d12] border border-[#1f2630] rounded-3xl p-6 flex flex-col shadow-lg relative overflow-hidden">
                <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-l from-amber-500 to-transparent"></div>
                <h3 class="text-xl font-black text-white mb-1 flex items-center gap-2"><span>👑</span> رسائل القيادة</h3>
                <p class="text-xs text-gray-500 mb-4 font-mono">المرشحين للفرز والاعتماد النهائي</p>
                
                <textarea id="msg-final" class="w-full h-32 bg-[#0d1117] border border-[#222b38] rounded-xl p-3 text-sm text-gray-300 font-mono resize-none focus:border-amber-500/50 outline-none mb-3" placeholder="اكتب رسالة الاعتماد هنا..."><%= templates.final %></textarea>
                <button onclick="saveTemp('final')" class="btn bg-[#161b22] hover:bg-[#1f2630] border border-[#222b38] text-gray-300 w-full !py-2 mb-6">💾 حفظ كقالب افتراضي</button>

                <div class="flex-1 bg-[#05070a] rounded-xl border border-[#1f2630] p-4 mb-4 overflow-y-auto max-h-48">
                    <h4 class="text-xs font-bold text-gray-400 mb-3 border-b border-[#1f2630] pb-2">القائمة المستهدفة (<%= finalUsers.length %>):</h4>
                    <% if(finalUsers.length === 0) { %>
                        <p class="text-xs text-gray-600 text-center mt-4">لا يوجد ملفات للفرز حالياً.</p>
                    <% } else { %>
                        <div class="flex flex-col gap-2">
                            <% finalUsers.forEach(u => { %>
                                <div class="text-[10px] font-mono text-gray-300 bg-[#0d1117] p-2 rounded-lg border border-[#1f2630] flex justify-between">
                                    <span class="font-bold truncate"><%= u.name %></span>
                                    <span class="text-amber-400">ID: <%= u.copyId %></span>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
                
                <button onclick="sendBulk('final', finalIds)" class="btn !bg-amber-600 hover:!bg-amber-500 w-full !py-3 shadow-[0_0_15px_rgba(245,158,11,0.3)]">🚀 إرسال الرسالة للجميع</button>
            </div>

        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
        // تمرير البيانات من السيرفر بشكل آمن ومخفي عن لجان فحص المحرر
const interviewIds = JSON.parse('<%- JSON.stringify(interviewUsers.map(u => u.id)) %>');
const prelimIds = JSON.parse('<%- JSON.stringify(prelimUsers.map(u => u.id)) %>');
const finalIds = JSON.parse('<%- JSON.stringify(finalUsers.map(u => u.id)) %>'); 
        async function saveTemp(type) {
            const msg = document.getElementById(`msg-${type}`).value.trim();
            if(!msg) return alert("لا يمكن حفظ رسالة فارغة!");
            
            try {
                const res = await fetch('/api/templates/save', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ type, message: msg })
                });
                const data = await res.json();
                if(data.success) alert("✅ تم حفظ القالب بنجاح في قاعدة البيانات.");
                else alert("⚠️ خطأ في الحفظ.");
            } catch (err) { alert("⚠️ تعذر الاتصال بالسيرفر."); }
        }

        async function sendBulk(type, usersArray) {
            if(usersArray.length === 0) return alert("لا يوجد أشخاص في هذه القائمة لإرسال الرسائل لهم!");
            
            const msg = document.getElementById(`msg-${type}`).value.trim();
            if(!msg) return alert("يرجى كتابة الرسالة أو حفظ القالب أولاً!");

            if(confirm(`🚨 تأكيد: هل أنت متأكد من إرسال هذه الرسالة كـ(خاص DM) لعدد (${usersArray.length}) شخص دفعة واحدة؟`)) {
                
                // إظهار اللودر (اذا كنت تستخدمه)
                if(typeof showLoader === 'function') showLoader();

                try {
                    const res = await fetch('/api/templates/send', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ users: usersArray, message: msg })
                    });
                    const data = await res.json();
                    
                    if(typeof hideLoader === 'function') hideLoader();

                    if(data.success) {
                        alert(`✅ اكتملت المهمة!\nتم الإرسال بنجاح لـ: ${data.successCount}\nفشل الإرسال لـ: ${data.failCount} (قد يكون مقفل الخاص)`);
                    } else {
                        alert(`⚠️ خطأ: ${data.error}`);
                    }
                } catch (err) { 
                    if(typeof hideLoader === 'function') hideLoader();
                    alert("⚠️ تعذر إرسال الرسائل."); 
                }
            }
        }
    </script>
</body>
</html>