<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>مركز المراسلات | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col bg-[#05070a] selection:bg-indigo-500 selection:text-white font-sans">
    <%- include('partials/navbar') %>

    <main class="max-w-[90rem] mx-auto px-6 py-12 flex-1 w-full">
        
        <div class="relative rounded-[2.5rem] bg-[#0d1117] border border-[#1f2630] p-10 md:p-12 mb-12 shadow-2xl overflow-hidden">
            <div class="absolute top-0 left-0 w-1/3 h-full bg-gradient-to-r from-indigo-900/20 to-transparent opacity-50"></div>
            <div class="relative z-10">
                <span class="inline-block bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 text-xs font-mono font-bold px-4 py-1.5 rounded-full uppercase tracking-widest mb-4">
                    COMMUNICATIONS CENTER
                </span>
                <h2 class="text-3xl md:text-4xl font-black text-white mb-2 tracking-wide">مركز المراسلات والتوجيه الآلي</h2>
                <p class="text-sm text-gray-400 max-w-2xl leading-relaxed">
                    من هنا يمكنك إعداد النماذج التلقائية التي تُرسل فور قبول العسكري، بالإضافة إلى إرسال رسائل بث عامة (Broadcast) لأي مجموعة أو لأشخاص محددين.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <!-- القسم الأول: قوالب الإرسال التلقائي -->
            <div class="bg-[#0a0d12] border border-[#1f2630] rounded-3xl p-8 relative shadow-lg">
                <div class="flex items-center gap-4 mb-8 border-b border-[#1f2630] pb-4">
                    <span class="text-3xl">⚙️</span>
                    <div>
                        <h3 class="text-xl font-black text-white">إعداد القوالب التلقائية</h3>
                        <p class="text-xs text-gray-500 mt-1">تُدمج هذه النصوص مع رسالة القبول وترسل آلياً</p>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <label class="text-xs font-bold text-orange-400 mb-2 block">نموذج القبول للمقابلة (المرحلة 1):</label>
                        <textarea id="tpl-interview" class="w-full h-20 bg-[#0d1117] border border-[#222b38] rounded-xl p-3 text-sm text-gray-300 font-mono resize-none focus:border-orange-500" placeholder="مثال: يرجى التوجه للانتظار غداً الساعة 9 م..."><%= templates.interview %></textarea>
                        <button onclick="saveTemp('interview', 'tpl-interview')" class="btn bg-[#161b22] hover:bg-orange-600 border border-[#222b38] text-white w-full mt-2 !py-2 text-xs">💾 حفظ قالب المقابلة</button>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-emerald-400 mb-2 block">نموذج دخول الميدان (المرحلة 2):</label>
                        <textarea id="tpl-preliminary" class="w-full h-20 bg-[#0d1117] border border-[#222b38] rounded-xl p-3 text-sm text-gray-300 font-mono resize-none focus:border-emerald-500" placeholder="مثال: يرجى لبس الزي الرياضي والتواجد في الميدان..."><%= templates.preliminary %></textarea>
                        <button onclick="saveTemp('preliminary', 'tpl-preliminary')" class="btn bg-[#161b22] hover:bg-emerald-600 border border-[#222b38] text-white w-full mt-2 !py-2 text-xs">💾 حفظ قالب الميدان</button>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-amber-400 mb-2 block">نموذج التخرج والاعتماد (المرحلة 3):</label>
                        <textarea id="tpl-final" class="w-full h-20 bg-[#0d1117] border border-[#222b38] rounded-xl p-3 text-sm text-gray-300 font-mono resize-none focus:border-amber-500" placeholder="مثال: يرجى التوجه لاستلام الرتبة والبدلة العسكرية..."><%= templates.final %></textarea>
                        <button onclick="saveTemp('final', 'tpl-final')" class="btn bg-[#161b22] hover:bg-amber-600 border border-[#222b38] text-white w-full mt-2 !py-2 text-xs">💾 حفظ قالب التخرج</button>
                    </div>
                </div>
            </div>

            <!-- القسم الثاني: البث العام (Broadcast) -->
            <div class="bg-[#0a0d12] border border-[#1f2630] rounded-3xl p-8 relative shadow-lg">
                <div class="flex items-center gap-4 mb-8 border-b border-[#1f2630] pb-4">
                    <span class="text-3xl">📢</span>
                    <div>
                        <h3 class="text-xl font-black text-white">نظام الإرسال العام (Broadcast)</h3>
                        <p class="text-xs text-gray-500 mt-1">إرسال رسالة مخصصة لجميع أفراد الفئة المحددة</p>
                    </div>
                </div>

                <div class="space-y-5">
                    <div>
                        <label class="text-xs font-bold text-gray-300 mb-2 block">1. اختر الفئة المستهدفة:</label>
                        <select id="targetGroup" onchange="toggleCustomInput()" class="w-full bg-[#0d1117] border border-[#222b38] rounded-xl p-3 text-sm text-white focus:border-indigo-500 outline-none">
                            <option value="raw">📝 تقديمات الشرطة الجديدة (<%= rawApps.length %>)</option>
                            <option value="interview">🎙️ المرشحين للمقابلات (<%= interviewUsers.length %>)</option>
                            <option value="preliminary">🛡️ المقبولين مبدئياً للميدان (<%= prelimUsers.length %>)</option>
                            <option value="final">👑 بانتظار الاعتماد النهائي (<%= finalUsers.length %>)</option>
                            <option value="custom">🎯 إرسال مخصص (للمرفوضين أو أفراد محددين)</option>
                        </select>
                    </div>

                    <!-- مربع الإدخال اليدوي (يظهر فقط عند اختيار "إرسال مخصص") -->
                    <div id="customInputContainer" class="hidden">
                        <label class="text-xs font-bold text-indigo-400 mb-2 block">الصق الأيديات (Copy IDs) هنا كل آيدي في سطر:</label>
                        <textarea id="customCopyIds" class="w-full h-24 bg-[#12171f] border border-[#222b38] rounded-xl p-3 text-sm text-gray-300 font-mono resize-none focus:border-indigo-500" placeholder="123456789012345678&#10;876543210987654321"></textarea>
                    </div>

                    <div>
                        <label class="text-xs font-bold text-gray-300 mb-2 block">2. اكتب رسالة البث العام:</label>
                        <textarea id="broadcastMsg" class="w-full h-32 bg-[#0d1117] border border-[#222b38] rounded-xl p-4 text-sm text-gray-200 font-mono resize-none focus:border-indigo-500" placeholder="اكتب إعلانك أو توجيهك هنا..."></textarea>
                    </div>

                    <button onclick="sendBroadcast()" class="btn !bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 w-full !py-3.5 shadow-[0_0_20px_rgba(79,70,229,0.4)] text-lg font-black tracking-widest mt-4">
                        🚀 إرسال الرسالة للمجموعة المحددة
                    </button>
                </div>
            </div>

        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
        // تمرير الايديات من السيرفر بشكل آمن
        const groupData = {
            raw: JSON.parse('<%- JSON.stringify(rawApps.map(u => u.copyId)) %>'),
            interview: JSON.parse('<%- JSON.stringify(interviewUsers.map(u => u.copyId)) %>'),
            preliminary: JSON.parse('<%- JSON.stringify(prelimUsers.map(u => u.copyId)) %>'),
            final: JSON.parse('<%- JSON.stringify(finalUsers.map(u => u.copyId)) %>')
        };

        // إظهار/إخفاء مربع الإدخال اليدوي بناءً على الاختيار
        function toggleCustomInput() {
            const group = document.getElementById('targetGroup').value;
            const customContainer = document.getElementById('customInputContainer');
            if (group === 'custom') {
                customContainer.classList.remove('hidden');
            } else {
                customContainer.classList.add('hidden');
            }
        }

        async function saveTemp(type, textareaId) {
            const msg = document.getElementById(textareaId).value.trim();
            try {
                const res = await fetch('/api/templates/save', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ type, message: msg })
                });
                if((await res.json()).success) alert("✅ تم تحديث القالب التلقائي.");
                else alert("⚠️ خطأ في الحفظ.");
            } catch (err) { alert("⚠️ تعذر الاتصال."); }
        }

        async function sendBroadcast() {
            const groupKey = document.getElementById('targetGroup').value;
            let copyIds = [];

            // تحديد قائمة الأيديات بناءً على الخيار
            if (groupKey === 'custom') {
                const rawText = document.getElementById('customCopyIds').value;
                // تقسيم النص حسب الأسطر واستخراج الأيديات الصالحة فقط
                copyIds = rawText.split('\n').map(id => id.trim()).filter(id => id.length >= 17);
                if(copyIds.length === 0) return alert("❌ يرجى لصق 'Copy ID' واحد صحيح على الأقل!");
            } else {
                copyIds = groupData[groupKey];
            }

            const msg = document.getElementById('broadcastMsg').value.trim();

            if(!msg) return alert("❌ يرجى كتابة الرسالة أولاً!");
            if(copyIds.length === 0) return alert("❌ لا يوجد أشخاص في هذه الفئة لإرسال الرسالة لهم!");

            if(confirm(`🚨 تأكيد: سيتم إرسال رسالة خاصة (DM) لعدد (${copyIds.length}) عسكري. هل أنت متأكد؟`)) {
                if(typeof showLoader === 'function') showLoader();

                try {
                    const res = await fetch('/api/templates/send', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ copyIds, message: msg })
                    });
                    const data = await res.json();
                    
                    if(typeof hideLoader === 'function') hideLoader();

                    if(data.success) {
                        let resultMsg = `✅ اكتملت المهمة!\n✔ تم الإرسال لـ: ${data.successCount}\n❌ فشل الإرسال لـ: ${data.failCount}`;
                        if(data.failCount > 0) resultMsg += `\n⚠️ سبب الفشل الدقيق من ديسكورد: ${data.errorLog}`;
                        alert(resultMsg);
                        
                        // تفريغ الخانات بعد الإرسال الناجح
                        document.getElementById('broadcastMsg').value = ''; 
                        if(groupKey === 'custom') document.getElementById('customCopyIds').value = '';
                    } else {
                        alert(`⚠️ خطأ: ${data.error}`);
                    }
                } catch (err) { 
                    if(typeof hideLoader === 'function') hideLoader();
                    alert("⚠️ تعذر إرسال الرسائل."); 
                }
            }
        }
    </script>
</body>
</html>