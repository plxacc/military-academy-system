<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>الرئيسية | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col bg-[#05070a] selection:bg-orange-500 selection:text-white font-sans">
    <%- include('partials/navbar') %>

    <main class="w-full max-w-[90rem] mx-auto px-6 py-12 flex-1">
        
        <!-- القسم التعريفي للمركز (تصميم فخم وكبير) -->
        <div class="relative rounded-[2.5rem] bg-[#0d1117] border border-[#1f2630] p-10 md:p-16 mb-12 shadow-2xl overflow-hidden">
            <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-[#161b22] to-transparent opacity-50"></div>
            <div class="relative z-10">
                <span class="inline-block bg-orange-500/10 text-orange-500 border border-orange-500/20 text-xs font-mono font-bold px-4 py-1.5 rounded-full uppercase tracking-widest mb-6">
                    CENTRAL COMMAND DASHBOARD
                </span>
                <h2 class="text-4xl md:text-5xl font-black text-white mb-4 leading-tight tracking-wide">
                    قيادة الاستقطاب العسكري - شرطة جستس
                </h2>
                <p class="text-base md:text-lg text-gray-400 max-w-3xl leading-relaxed">
                    نظام الكلية العسكرية التابعة لشرطة جستس المخصص لإدارة طلبات الالتحاق ورصد درجات التأهيل الميداني بدقة واحترافية عالية.
                </p>
            </div>
        </div>

        <!-- أرقام وإحصائيات المنظومة (كروت نظيفة وخفيفة) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-20">
            <div class="relative bg-[#0d1117] border border-[#1f2630] p-8 rounded-3xl overflow-hidden hover:border-gray-600 transition-colors">
                <div class="absolute right-0 top-0 w-1.5 h-full bg-gray-600"></div>
                <span class="text-sm text-gray-500 font-bold block mb-3 uppercase tracking-wider">إجمالي المتقدمين</span>
                <span class="text-5xl font-black text-white font-mono tracking-tighter"><%= stats.totalCount %></span>
            </div>
            
            <div class="relative bg-[#0d1117] border border-[#1f2630] p-8 rounded-3xl overflow-hidden hover:border-teal-500/50 transition-colors">
                <div class="absolute right-0 top-0 w-1.5 h-full bg-teal-500/70"></div>
                <span class="text-sm text-gray-500 font-bold block mb-3 uppercase tracking-wider">ميدان التدريب الحالي</span>
                <span class="text-5xl font-black text-teal-400 font-mono tracking-tighter"><%= stats.prelimCount %></span>
            </div>
            
            <div class="relative bg-[#0d1117] border border-[#1f2630] p-8 rounded-3xl overflow-hidden hover:border-emerald-500/50 transition-colors">
                <div class="absolute right-0 top-0 w-1.5 h-full bg-emerald-500/70"></div>
                <span class="text-sm text-gray-500 font-bold block mb-3 uppercase tracking-wider">المجتازين للدورة</span>
                <span class="text-5xl font-black text-emerald-400 font-mono tracking-tighter"><%= stats.passedCount %></span>
            </div>
            
            <div class="relative bg-[#0d1117] border border-[#1f2630] p-8 rounded-3xl overflow-hidden hover:border-red-500/50 transition-colors">
                <div class="absolute right-0 top-0 w-1.5 h-full bg-red-500/70"></div>
                <span class="text-sm text-gray-500 font-bold block mb-3 uppercase tracking-wider">الملفات المرفوضة</span>
                <span class="text-5xl font-black text-red-400 font-mono tracking-tighter"><%= stats.failedCount %></span>
            </div>
        </div>

        <!-- الهيكل القيادي للمنظومة -->
        <div class="mb-24">
            <div class="flex items-center gap-4 mb-10">
                <h3 class="text-2xl font-black text-white uppercase tracking-widest">الهيكل الاداري للكلية العسكرية</h3>
                <div class="flex-1 h-px bg-gradient-to-l from-[#1f2630] to-transparent"></div>
            </div>
            
            <!-- مسؤول الكلية (مستوى القيادة الأعلى) -->
            <div class="max-w-3xl mx-auto bg-[#0d1117] border border-amber-500/30 rounded-[2rem] p-10 text-center relative shadow-[0_0_40px_rgba(245,158,11,0.05)] mb-10">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/3 h-1.5 bg-amber-500 rounded-b-md"></div>
                <h4 class="text-4xl font-black text-white mb-3 tracking-wide">بيدرو الشمري</h4>
                <p class="text-base text-amber-500 font-bold uppercase tracking-widest mb-6">مسؤول الكلية العسكرية</p>
                <div class="text-sm text-gray-400 font-mono bg-[#161b22] px-6 py-3 rounded-xl border border-[#222b38] inline-block">
                    الإشراف العام والاعتماد المباشر لكافة القرارات التنظيمية
                </div>
            </div>

            <!-- المساعدين والمشرفين (مستوى القيادة الإشرافي) -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- نائب المسؤول -->
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-[2rem] p-8 text-center hover:bg-[#121820] transition-all relative overflow-hidden group">
                    <div class="absolute bottom-0 left-0 w-full h-1 bg-blue-500/30 group-hover:bg-blue-500/60 transition-colors"></div>
                    <h4 class="text-2xl font-black text-white mb-2">جو ريستوفا</h4>
                    <p class="text-sm text-blue-400 font-bold mb-5 tracking-wide">نائب مسؤول الكلية ومسؤول العمليات</p>
                    <div class="text-xs text-gray-400 font-mono leading-relaxed bg-[#05070a] p-4 rounded-xl border border-[#1f2630]">
                        نائب المسؤول ومسؤول تدريب العمليات وأعضاء تدريب العمليات ومسؤول الرصد والتقييم النهائي للعمليات.
                    </div>
                </div>

                <!-- مشرف التدريب والتفاوض -->
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-[2rem] p-8 text-center hover:bg-[#121820] transition-all relative overflow-hidden group">
                    <div class="absolute bottom-0 left-0 w-full h-1 bg-emerald-500/30 group-hover:bg-emerald-500/60 transition-colors"></div>
                    <h4 class="text-2xl font-black text-white mb-2">عبدالعزيز الحربي</h4>
                    <p class="text-sm text-emerald-400 font-bold mb-5 tracking-wide">مشرف التدريب ومسؤول الأنظمة والتفاوض</p>
                    <div class="text-xs text-gray-400 font-mono leading-relaxed bg-[#05070a] p-4 rounded-xl border border-[#1f2630]">
                        مشرف تدريب الكلية لكل الاختبارات الميدانية ومسؤول تدريب التفاوض وأعضاء تدريب التفاوض ومسؤول عن رصد وتقييم مهارات التفاوض والتعامل مع المواقف الحرجة.
                    </div>
                </div>

                <!-- مشرف التدريب والاستيقافات -->
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-[2rem] p-8 text-center hover:bg-[#121820] transition-all relative overflow-hidden group">
                    <div class="absolute bottom-0 left-0 w-full h-1 bg-teal-500/30 group-hover:bg-teal-500/60 transition-colors"></div>
                    <h4 class="text-2xl font-black text-white mb-2">بهاء خالد</h4>
                    <p class="text-sm text-teal-400 font-bold mb-5 tracking-wide">مشرف التدريب ومسؤول الاستيقافات</p>
                    <div class="text-xs text-gray-400 font-mono leading-relaxed bg-[#05070a] p-4 rounded-xl border border-[#1f2630]">
                        مشرف تدريب الكلية لكل الاختبارات الميدانية ومسؤول تدريب الاستيقافات وأعضاء تدريب الاستيقافات ومسؤول عن رصد وتقييم مهارات الاستيقافات المرورية، الجنائية، الإجبارية.
                    </div>
                </div>
            </div>
        </div>

        <!-- سجل أعضاء وهيئة تدريب الكلية (التصميم الجديد للكروت) -->
        <div>
            <div class="flex items-center gap-4 mb-8">
                <h3 class="text-2xl font-black text-white uppercase tracking-widest">سجل أعضاء وهيئة تدريب الكلية</h3>
                <div class="flex-1 h-px bg-gradient-to-l from-[#1f2630] to-transparent"></div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <% if(typeof trainers !== 'undefined' && trainers.length > 0) { %>
                    <% trainers.forEach(trainer => { %>
                        <!-- كرت تعريف المدرب الجديد -->
                        <div class="relative bg-[#0d1117] border border-[#1f2630] rounded-2xl p-6 hover:bg-[#121820] hover:border-gray-600 transition-all group overflow-hidden flex flex-col justify-between min-h-[160px]">
                            <div class="absolute right-0 top-0 w-1 h-full bg-gray-700 group-hover:bg-gray-400 transition-colors"></div>
                            
                            <div class="mb-4">
                                <h5 class="text-xl font-black text-white mb-1 truncate tracking-wide"><%= trainer.name %></h5>
                                <p class="text-xs font-bold text-gray-500 tracking-wider uppercase"><%= trainer.role %></p>
                            </div>
                            
                            <div class="bg-[#05070a] border border-[#222b38] rounded-xl p-3 text-xs text-gray-400 font-mono leading-relaxed">
                                <%= trainer.duty %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full bg-[#0d1117] border border-dashed border-[#222b38] rounded-3xl p-12 text-center text-gray-500">
                        <p class="text-base font-bold font-mono tracking-widest uppercase">لا توجد أسماء مسجلة في كادر التدريب حالياً</p>
                    </div>
                <% } %>
            </div>
        </div>

    </main>

    <%- include('partials/footer') %>
</body>
</html>