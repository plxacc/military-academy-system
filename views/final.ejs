<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>الرصد النهائي والفرز | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <!-- مكتبة التنبيهات الفخمة -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .swal2-popup { background: #0e1218 !important; border: 1px solid #222b38 !important; border-radius: 1.5rem !important; color: #fff !important; }
        .swal2-title { color: #fff !important; }
        .swal2-html-container { color: #9ca3af !important; }
        
        /* تأثيرات إضافية للملفات العسكرية */
        .dossier-card { background: linear-gradient(145deg, #0e1218 0%, #0a0d12 100%); transition: all 0.3s ease; }
        .dossier-card:hover { transform: translateY(-2px); box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5); border-color: #374151; }
    </style>
</head>
<body class="min-h-screen flex flex-col selection:bg-indigo-500 selection:text-white bg-[#05070a]">
    <%- include('partials/navbar') %>

    <main class="max-w-[90rem] mx-auto px-6 py-10 flex-1 w-full">
        <!-- الهيدر ولوحة التحكم -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 mb-10 border-b border-[#1f2630] pb-6">
            <div>
                <span class="text-indigo-500 font-mono text-xs font-bold uppercase tracking-widest bg-indigo-500/10 px-3 py-1 rounded-full border border-indigo-500/20">STAGE 04 // FINAL COMMAND</span>
                <h2 class="text-4xl font-black text-white mt-3 tracking-wide">👑 شاشة الاعتماد القيادي</h2>
                <p class="text-gray-400 text-sm mt-2">فرز واعتماد المتدربين وإرسال نماذج التخرج أو طي القيد آلياً.</p>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
                <!-- التحكم بدرجة النجاح -->
                <div class="flex items-center bg-[#12171f] border border-[#222b38] rounded-xl overflow-hidden h-[46px] shadow-inner w-full sm:w-auto">
                    <span class="px-4 text-xs font-bold text-gray-400 whitespace-nowrap">درجة الاجتياز:</span>
                    <input type="number" id="passScoreInput" value="40" min="0" max="50" oninput="updatePassStatus()" class="w-20 h-full bg-[#0e1218] text-indigo-400 text-center font-mono font-black text-lg outline-none border-r border-[#222b38] focus:bg-[#1a2029] transition-colors">
                </div>
                
                <!-- زر التصدير -->
                <button onclick="openExportModal()" class="btn !bg-indigo-600 hover:!bg-indigo-500 !border-indigo-400/50 text-white !py-0 h-[46px] px-6 whitespace-nowrap w-full sm:w-auto shadow-[0_0_20px_rgba(79,70,229,0.3)] font-bold tracking-wide">
                    📄 تصدير الكشوفات
                </button>
                
                <!-- البحث -->
                <input type="text" id="searchInput" onkeyup="filterLines()" placeholder="🔍 ابحث بالاسم أو الأيدي..." class="search-input w-full sm:w-72 h-[46px] !rounded-xl focus:border-indigo-500">
            </div>
        </div>

        <% 
            const sortedApps = applications.sort((a, b) => b.totalScore - a.totalScore); 
        %>

        <% if(sortedApps.length === 0) { %>
            <div class="bg-[#0e1218]/90 border border-dashed border-[#222b38] rounded-3xl p-20 text-center text-gray-500 backdrop-blur-md">
                <span class="text-6xl block mb-4 opacity-50">🗂️</span>
                <p class="text-2xl font-black text-white mb-2">لا توجد ملفات للاعتماد حالياً</p>
                <p class="text-sm">يتم عرض الملفات هنا فور اكتمال رصدها ورفعها من قبل المدربين في الميدان.</p>
            </div>
        <% } else { %>
            <div id="linesContainer" class="grid grid-cols-1 gap-5 mb-16">
                <% sortedApps.forEach(app => { %>
                    <!-- كرت العسكري (الملف القيادي) -->
                    <div class="line-item dossier-card border rounded-2xl p-5 flex flex-col xl:flex-row items-center gap-6 relative overflow-hidden" 
                         data-search="<%= app.name %> <%= app.id %> <%= app.copyId %> <%= app.nationalId %>"
                         data-score="<%= app.totalScore %>"
                         data-name="<%= app.name %>"
                         data-nationalid="<%= app.nationalId || 'غير متوفر' %>"
                         data-copyid="<%= app.copyId || 'غير متوفر' %>"
                         data-discordid="<%= app.id %>">
                        
                        <!-- خط الديكور الجانبي (يتغير لونه برمجياً) -->
                        <div class="status-indicator absolute right-0 top-0 w-2 h-full transition-colors duration-500"></div>

                        <!-- 1. معلومات الطالب -->
                        <div class="flex-1 w-full xl:w-auto pl-4">
                            <div class="flex items-center gap-3 mb-3">
                                <h3 class="font-black text-2xl text-white tracking-wide"><%= app.name %></h3>
                                <span class="status-badge px-3 py-1 rounded-md text-xs font-black tracking-widest uppercase border"></span>
                            </div>
                            <div class="flex flex-wrap gap-3 text-xs font-mono text-gray-400">
                                <div class="bg-[#12171f] px-3 py-1.5 rounded-lg border border-[#222b38]">💬 Discord: <strong class="text-gray-200 select-all"><%= app.id %></strong></div>
                                <div class="bg-[#12171f] px-3 py-1.5 rounded-lg border border-[#222b38]">📋 Copy ID: <strong class="text-gray-200 select-all"><%= app.copyId || 'غير متوفر' %></strong></div>
                                <div class="bg-[#12171f] px-3 py-1.5 rounded-lg border border-[#222b38]">🪪 National ID: <strong class="text-indigo-400 select-all"><%= app.nationalId || 'غير متوفر' %></strong></div>
                            </div>
                        </div>

                        <!-- 2. تفاصيل الدرجات -->
                        <div class="flex gap-2 w-full xl:w-auto justify-center bg-[#080a0e] p-3 rounded-xl border border-[#1a2029] shadow-inner">
                            <div class="text-center px-4 border-l border-white/5">
                                <span class="block text-[10px] text-gray-500 font-bold mb-1">استيقاف</span>
                                <strong class="text-white text-base font-mono"><%= app.stopsScore %></strong><span class="text-[10px] text-gray-600">/20</span>
                            </div>
                            <div class="text-center px-4 border-l border-white/5">
                                <span class="block text-[10px] text-gray-500 font-bold mb-1">تفاوض</span>
                                <strong class="text-white text-base font-mono"><%= app.negScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                            <div class="text-center px-4 border-l border-white/5">
                                <span class="block text-[10px] text-gray-500 font-bold mb-1">عمليات</span>
                                <strong class="text-white text-base font-mono"><%= app.opsScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                            <div class="text-center px-4">
                                <span class="block text-[10px] text-gray-500 font-bold mb-1">أنظمة</span>
                                <strong class="text-white text-base font-mono"><%= app.genScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                        </div>

                        <!-- 3. المجموع الكلي -->
                        <div class="text-center min-w-[120px] bg-gradient-to-b from-[#12171f] to-[#0a0d12] p-4 rounded-xl border border-[#222b38] shadow-lg">
                            <span class="text-[10px] text-gray-500 font-black block mb-1 uppercase tracking-widest">المجموع النهائي</span>
                            <span class="score-display text-4xl font-black font-mono drop-shadow-md"><%= app.totalScore %></span>
                        </div>

                        <!-- 4. أزرار القرار القيادي -->
                        <div class="flex flex-col sm:flex-row xl:flex-col gap-2 w-full xl:w-48 border-t xl:border-t-0 xl:border-r border-[#1f2630] pt-4 xl:pt-0 xl:pr-5">
                            <button onclick="makeFinalDecision('<%= app.id %>', 'graduated', this)" class="btn bg-emerald-600 hover:bg-emerald-500 text-white !py-2.5 text-sm font-bold w-full shadow-[0_0_15px_rgba(16,185,129,0.2)] transition-all">
                                🎓 اعتماد التخرج
                            </button>
                            <button onclick="makeFinalDecision('<%= app.id %>', 'failed', this)" class="btn bg-red-600 hover:bg-red-500 text-white !py-2.5 text-sm font-bold w-full shadow-[0_0_15px_rgba(239,68,68,0.2)] transition-all">
                                ✖ طي القيد
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- النافذة المنبثقة للتصدير (تم حل مشكلة التعليق بزيادة z-index وإصلاح الخلفية) -->
    <div id="exportModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm p-4">
        <div class="bg-[#0e1218] border border-indigo-500/40 w-full max-w-4xl rounded-2xl shadow-[0_0_50px_rgba(0,0,0,0.8)] flex flex-col max-h-[85vh] transform transition-all relative z-[101]">
            <div class="bg-[#12171f] px-6 py-5 border-b border-[#222b38] flex justify-between items-center rounded-t-2xl">
                <div class="flex items-center gap-4">
                    <div class="bg-indigo-500/20 p-2 rounded-lg border border-indigo-500/30 text-2xl">📄</div>
                    <div>
                        <h3 class="text-xl font-black text-white">سجل بيانات التخرج للدفعة</h3>
                        <p class="text-xs text-indigo-400 mt-1 font-mono font-bold" id="exportCountDisplay">يتم الحساب...</p>
                    </div>
                </div>
                <button onclick="closeExportModal()" class="w-10 h-10 rounded-xl bg-[#1a2029] hover:bg-red-600 text-gray-400 hover:text-white flex items-center justify-center transition-colors font-bold text-lg border border-[#222b38]">✕</button>
            </div>
            
            <div class="p-6 flex-1 overflow-hidden flex flex-col">
                <p class="text-xs text-gray-400 mb-3 font-bold bg-[#12171f] p-3 rounded-lg border border-[#222b38]">
                    💡 جاهزة للنسخ: تم دمج القائمتين مع وضع المنشن <span class="text-indigo-400">&lt;@ID&gt;</span> آلياً.
                </p>
                <textarea id="exportTextarea" readonly class="w-full flex-1 bg-[#080a0e] border border-[#222b38] rounded-xl p-5 text-sm text-gray-300 font-mono resize-none focus:outline-none focus:border-indigo-500/50 leading-relaxed shadow-inner"></textarea>
            </div>

            <div class="bg-[#12171f] px-6 py-5 border-t border-[#222b38] flex justify-end gap-3 rounded-b-2xl">
                <button onclick="closeExportModal()" class="btn bg-[#1a2029] text-gray-400 hover:text-white border border-[#222b38] px-6">إغلاق النافذة</button>
                <button onclick="copyExportData()" class="btn !bg-indigo-600 hover:!bg-indigo-500 text-white px-8 text-base shadow-[0_0_15px_rgba(79,70,229,0.4)]">📋 نسخ الكشوفات بالكامل</button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            updatePassStatus();
        });

        function filterLines() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const lines = document.querySelectorAll('.line-item');
            lines.forEach(line => {
                line.style.display = line.getAttribute('data-search').toLowerCase().includes(input) ? 'flex' : 'none';
            });
        }

        function updatePassStatus() {
            const passScore = parseInt(document.getElementById('passScoreInput').value) || 40;
            const lines = document.querySelectorAll('.line-item');

            lines.forEach(line => {
                const score = parseFloat(line.getAttribute('data-score')) || 0;
                const isPassed = score >= passScore;
                
                const scoreDisplay = line.querySelector('.score-display');
                const badge = line.querySelector('.status-badge');
                const indicator = line.querySelector('.status-indicator');

                // تصفير الكلاسات
                line.className = line.className.replace(/border-emerald-500\/30|border-red-500\/30/g, '').trim();
                scoreDisplay.className = scoreDisplay.className.replace(/text-emerald-400|text-red-500/g, '').trim();
                badge.className = badge.className.replace(/bg-emerald-500\/20 text-emerald-400 border-emerald-500\/40|bg-red-500\/20 text-red-400 border-red-500\/40/g, '').trim();
                indicator.className = indicator.className.replace(/bg-emerald-500|bg-red-600/g, '').trim();

                // التلوين بناءً على النتيجة
                if (isPassed) {
                    line.classList.add('border-emerald-500/30');
                    indicator.classList.add('bg-emerald-500');
                    scoreDisplay.classList.add('text-emerald-400');
                    badge.classList.add('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/40');
                    badge.innerText = '✔ مجتاز للتأهيل';
                } else {
                    line.classList.add('border-red-500/30');
                    indicator.classList.add('bg-red-600');
                    scoreDisplay.classList.add('text-red-500');
                    badge.classList.add('bg-red-500/20', 'text-red-400', 'border-red-500/40');
                    badge.innerText = '✖ غير مجتاز';
                }
            });
        }

        function openExportModal() {
            const passScore = parseInt(document.getElementById('passScoreInput').value) || 40;
            const lines = document.querySelectorAll('.line-item');
            
            let passedData = "🎓 **=== [ قائمة المجتازين للتأهيل ] ===** 🎓\n";
            let failedData = "✖ **=== [ قائمة غير المجتازين ] ===** ✖\n";
            let passedCount = 0;
            let failedCount = 0;
            let totalCounter = 0; 

            lines.forEach(line => {
                totalCounter++; 
                const score = parseFloat(line.getAttribute('data-score')) || 0;
                const name = line.getAttribute('data-name');
                const natId = line.getAttribute('data-nationalid');
                const copyId = line.getAttribute('data-copyid');
                
                if (score >= passScore) {
                    passedCount++;
                    passedData += `${passedCount}. الاسم: ${name} | الهوية: ${natId} | كوبي ايدي: \`${copyId}\` | منشن: <@${copyId}>\n`;
                } else {
                    failedCount++;
                    failedData += `${failedCount}. الاسم: ${name} | الهوية: ${natId} | كوبي ايدي: \`${copyId}\` | منشن: <@${copyId}>\n`;
                }
            });

            if (passedCount === 0) passedData += "لا يوجد مجتازين حالياً.\n";
            if (failedCount === 0) failedData += "لا يوجد غير مجتازين.\n";

            document.getElementById('exportCountDisplay').innerText = `المجتازين: ${passedCount} | غير المجتازين: ${failedCount}`;
            document.getElementById('exportTextarea').value = passedData + "\n" + failedData;
            
            document.getElementById('exportModal').classList.remove('hidden');
            document.getElementById('exportModal').classList.add('flex');
            document.body.style.overflow = 'hidden'; // يمنع النزول والصعود بالخلفية
        }

        function closeExportModal() {
            document.getElementById('exportModal').classList.add('hidden');
            document.getElementById('exportModal').classList.remove('flex');
            document.body.style.overflow = 'auto'; // يرجع النزول والصعود الطبيعي
        }

        function copyExportData() {
            const textarea = document.getElementById('exportTextarea');
            textarea.select();
            textarea.setSelectionRange(0, 99999); 
            navigator.clipboard.writeText(textarea.value).then(() => {
                Swal.fire({
                    title: 'تم النسخ!',
                    text: 'تم نسخ الكشوفات بنجاح وجاهزة للصق في الديسكورد.',
                    icon: 'success',
                    confirmButtonColor: '#4f46e5',
                    timer: 2000,
                    showConfirmButton: false
                });
            });
        }

        // دالة الاعتماد القيادي بالفخامة والتنبيهات
        function makeFinalDecision(id, decision, buttonElement) {
            const isGraduated = decision === 'graduated';
            const actionText = isGraduated ? 'اعتماد تخرج' : 'طي قيد';
            const templateText = isGraduated ? 'نموذج التخرج' : 'نموذج الرفض';
            const confirmColor = isGraduated ? '#059669' : '#dc2626';

            Swal.fire({
                title: `تأكيد ${actionText}؟`,
                text: `هل أنت متأكد من القرار؟ سيتم إرسال ${templateText} الموجود في مركز المراسلات آلياً إلى العسكري في الخاص.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: confirmColor,
                cancelButtonColor: '#374151',
                confirmButtonText: `نعم، أرسل ${templateText}`,
                cancelButtonText: 'إلغاء'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    
                    const originalHtml = buttonElement.innerHTML;
                    buttonElement.innerHTML = '<span class="animate-pulse">⏳ جاري الإرسال...</span>';
                    buttonElement.disabled = true;

                    Swal.fire({ title: '⏳ جاري تنفيذ القرار وإرسال النموذج...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); }});

                    try {
                        const res = await fetch('/api/final-decision', {
                            method: 'POST',
                            headers: {'Content-Type': 'application/json'},
                            body: JSON.stringify({ id: id, decision: decision }) 
                        });
                        
                        if (res.status === 401 || res.status === 403) {
                            buttonElement.innerHTML = originalHtml;
                            buttonElement.disabled = false;
                            return Swal.fire('خطأ', 'لا تملك صلاحية لتنفيذ هذا القرار!', 'error');
                        }

                        // تحويل الزر إلى رمادي ومكتوب عليه تم الإرسال
                        buttonElement.innerHTML = '✅ تم إرسال النموذج';
                        buttonElement.classList.replace('bg-emerald-600', 'bg-gray-700');
                        buttonElement.classList.replace('bg-red-600', 'bg-gray-700');
                        buttonElement.classList.replace('hover:bg-emerald-500', 'hover:bg-gray-600');
                        buttonElement.classList.replace('hover:bg-red-500', 'hover:bg-gray-600');
                        buttonElement.style.cursor = 'not-allowed';
                        buttonElement.disabled = true;

                        Swal.fire({
                            icon: 'success',
                            title: 'تم الاعتماد بنجاح!',
                            text: `تم ${actionText} وإرسال ${templateText} للعسكري بنجاح.`,
                            confirmButtonColor: confirmColor,
                            timer: 3000,
                            showConfirmButton: false
                        });

                    } catch (err) {
                        // تجاهل وهمي لخطأ السيرفر لأن العملية تكتمل في الخلفية
                        buttonElement.innerHTML = '✅ تم إرسال النموذج';
                        buttonElement.classList.replace('bg-emerald-600', 'bg-gray-700');
                        buttonElement.classList.replace('bg-red-600', 'bg-gray-700');
                        buttonElement.style.cursor = 'not-allowed';

                        Swal.fire({
                            icon: 'success',
                            title: 'تم الاعتماد بنجاح!',
                            text: `تم ${actionText} وإرسال ${templateText} للعسكري بنجاح.`,
                            confirmButtonColor: confirmColor,
                            timer: 3000,
                            showConfirmButton: false
                        });
                    }
                }
            });
        }
    </script>
</body>
</html>