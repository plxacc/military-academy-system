<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>الرصد النهائي والفرز | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col selection:bg-indigo-500 selection:text-white">
    <%- include('partials/navbar') %>

    <main class="max-w-7xl mx-auto px-6 py-10 flex-1 w-full">
        <!-- الهيدر -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 mb-8 border-b border-[#1f2630] pb-5">
            <div>
                <span class="text-indigo-400 font-mono text-xs font-bold uppercase tracking-widest">STAGE 04 // FINAL COMMAND REVIEW</span>
                <h2 class="text-3xl font-black text-white mt-1">👑 شاشة الفرز واعتماد التخرج</h2>
            </div>
            <div class="flex items-center gap-3 w-full md:w-auto">
                <input type="text" id="searchInput" onkeyup="filterLines()" placeholder="🔍 ابحث بالاسم أو الأيدي..." class="search-input md:w-80">
            </div>
        </div>

        <% 
            // فرز تلقائي من الأعلى درجة إلى الأقل بدون أرقام مراكز
            const sortedApps = applications.sort((a, b) => b.totalScore - a.totalScore); 
        %>

        <% if(sortedApps.length === 0) { %>
            <div class="bg-[#0e1218]/90 border border-dashed border-[#222b38] rounded-2xl p-16 text-center text-gray-500 backdrop-blur-md">
                <span class="text-4xl block mb-3">👑</span>
                <p class="text-lg font-bold">لا يوجد ملفات بانتظار الاعتماد النهائي حالياً.</p>
            </div>
        <% } else { %>
            <!-- حاوية الخطوط العرضية (Rows) بدلاً من المربعات -->
            <div id="linesContainer" class="flex flex-col gap-4 mb-16">
                <% sortedApps.forEach(app => { 
                    const isPassed = app.totalScore >= 40;
                    const isException = app.status.includes('استثناء');
                    const isQualified = isPassed || isException;
                    
                    // تحديد الألوان بناءً على حالة النجاح/الرسوب/الاستثناء
                    const borderColor = isQualified ? (isException ? 'border-indigo-500/50' : 'border-emerald-500/50') : 'border-red-500/50';
                    const scoreColor = isQualified ? (isException ? 'text-indigo-400' : 'text-emerald-400') : 'text-red-500';
                    const glowEffect = isQualified ? (isException ? 'shadow-[0_0_15px_rgba(99,102,241,0.1)]' : 'shadow-[0_0_15px_rgba(16,185,129,0.1)]') : '';
                %>
                    <!-- الخط العرضي الواحد -->
                    <div class="line-item flex flex-col xl:flex-row items-center justify-between bg-[#0e1218]/90 border <%= borderColor %> rounded-2xl p-4 gap-6 transition-all duration-300 hover:bg-[#12171f] <%= glowEffect %>" data-search="<%= app.name %> <%= app.id %> <%= app.copyId %> <%= app.nationalId %>">
                        
                        <!-- 1. معلومات الطالب الأساسية -->
                        <div class="flex-1 w-full xl:w-auto">
                            <div class="flex items-center gap-3 mb-2">
                                <h3 class="font-black text-xl text-white"><%= app.name %></h3>
                                <% if(isException) { %>
                                    <span class="bg-indigo-500/20 text-indigo-400 border border-indigo-500/30 px-2 py-0.5 rounded text-[10px] font-bold">✨ نجاح استثنائي</span>
                                <% } %>
                            </div>
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 text-[10px] font-mono text-gray-400 bg-black/30 p-2 rounded-lg border border-white/5">
                                <div>💬 Discord: <strong class="text-gray-200 select-all"><%= app.id %></strong></div>
                                <div>📋 Copy ID: <strong class="text-gray-200 select-all"><%= app.copyId || 'غير متوفر' %></strong></div>
                                <div>🪪 National ID: <strong class="text-gray-200 select-all"><%= app.nationalId || 'غير متوفر' %></strong></div>
                            </div>
                        </div>

                        <!-- 2. تفاصيل الدرجات (بوكسات صغيرة مصفوفة) -->
                        <div class="flex flex-wrap sm:flex-nowrap gap-2 w-full xl:w-auto justify-center bg-[#080a0e] p-2.5 rounded-xl border border-[#1a2029]">
                            <div class="text-center px-3 border-l border-white/5 last:border-0">
                                <span class="block text-[10px] text-gray-500 mb-1">استيقاف</span>
                                <strong class="text-white text-sm font-mono"><%= app.stopsScore %></strong><span class="text-[10px] text-gray-600">/20</span>
                            </div>
                            <div class="text-center px-3 border-l border-white/5 last:border-0">
                                <span class="block text-[10px] text-gray-500 mb-1">تفاوض</span>
                                <strong class="text-white text-sm font-mono"><%= app.negScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                            <div class="text-center px-3 border-l border-white/5 last:border-0">
                                <span class="block text-[10px] text-gray-500 mb-1">عمليات</span>
                                <strong class="text-white text-sm font-mono"><%= app.opsScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                            <div class="text-center px-3">
                                <span class="block text-[10px] text-gray-500 mb-1">أنظمة</span>
                                <strong class="text-white text-sm font-mono"><%= app.genScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                        </div>

                        <!-- 3. النتيجة النهائية -->
                        <div class="text-center min-w-[90px]">
                            <span class="text-[10px] text-gray-500 font-bold block mb-1 uppercase tracking-wider">Final Score</span>
                            <span class="text-3xl font-black font-mono <%= scoreColor %>"><%= app.totalScore %></span>
                        </div>

                        <!-- 4. أزرار التحكم والقرارات -->
                        <% if(user.permissions.canApproveReject) { %>
                            <div class="flex flex-col sm:flex-row xl:flex-col gap-2 w-full xl:w-48">
                                <!-- زر الاعتماد / الرفض بناءً على الأهلية -->
                                <% if(isQualified) { %>
                                    <button onclick="commitFinal('<%= app.id %>', '<%= app.name %>', 'graduated')" class="btn btn-accept !py-2 w-full text-[11px]">🎓 اعتماد التخرج</button>
                                <% } else { %>
                                    <button onclick="commitFinal('<%= app.id %>', '<%= app.name %>', 'failed')" class="btn btn-reject !py-2 w-full text-[11px]">✖ طي قيد (رسوب)</button>
                                <% } %>

                                <!-- زر الاستثناء (يظهر فقط للي درجاتهم تحت 40) -->
                                <% if(!isPassed) { %>
                                    <% if(isException) { %>
                                        <button onclick="toggleAppException('<%= app.id %>', '<%= app.name %>', 'remove')" class="btn bg-orange-600/10 text-orange-400 border border-orange-500/20 hover:bg-orange-600 hover:text-white !py-2 w-full text-[11px] transition">
                                            إلغاء الاستثناء
                                        </button>
                                    <% } else { %>
                                        <button onclick="toggleAppException('<%= app.id %>', '<%= app.name %>', 'add')" class="btn bg-indigo-600/10 text-indigo-400 border border-indigo-500/20 hover:bg-indigo-600 hover:text-white !py-2 w-full text-[11px] transition">
                                            ✨ منح نجاح استثنائي
                                        </button>
                                    <% } %>
                                <% } %>
                            </div>
                        <% } else { %>
                            <div class="text-center bg-[#161b22] py-2 px-4 rounded-xl text-[10px] text-gray-500 font-bold">🔒 صلاحية القيادة</div>
                        <% } %>

                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <%- include('partials/footer') %>

    <script>
        function filterLines() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const lines = document.querySelectorAll('.line-item');
            lines.forEach(line => {
                line.style.display = line.getAttribute('data-search').toLowerCase().includes(input) ? 'flex' : 'none';
            });
        }

        // دالة الاستثناء الذكية
        async function toggleAppException(id, name, action) {
            const msg = action === 'add' 
                ? `هل أنت متأكد من منح المتدرب (${name}) نجاحاً استثنائياً لتأهيله للتخرج؟` 
                : `هل أنت متأكد من سحب الاستثناء من المتدرب (${name}) وإعادته كراسب؟`;
            
            if (confirm(msg)) {
                try {
                    const res = await fetch('/api/toggle-exception', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id, action })
                    });
                    const result = await res.json();
                    if (result.success) location.reload();
                    else alert('⚠️ خطأ: ' + result.error);
                } catch (error) {
                    alert('⚠️ تعذر الاتصال بالسيرفر.');
                }
            }
        }

        // دالة الاعتماد النهائي لإنهاء مسيرة المتدرب
        async function commitFinal(id, name, decision) {
            const msg = decision === 'graduated'
                ? `🎓 هل تعتمد تخرج المتدرب (${name}) وإغلاق ملفه كضابط جديد؟`
                : `✖ هل تعتمد رسوب المتدرب (${name}) وطي قيده نهائياً؟`;

            if (confirm(msg)) {
                try {
                    const res = await fetch('/api/final-decision', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id, decision })
                    });
                    const result = await res.json();
                    if (result.success) location.reload();
                    else alert('⚠️ خطأ: ' + result.error);
                } catch (error) {
                    alert('⚠️ تعذر الاتصال بالسيرفر.');
                }
            }
        }
    </script>
</body>
</html>