<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>الرصد النهائي والفرز | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col selection:bg-indigo-500 selection:text-white">
    <%- include('partials/navbar') %>

    <main class="max-w-[90rem] mx-auto px-6 py-10 flex-1 w-full">
        <!-- الهيدر ولوحة التحكم الديناميكية -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 mb-8 border-b border-[#1f2630] pb-5">
            <div>
                <span class="text-indigo-400 font-mono text-xs font-bold uppercase tracking-widest">STAGE 04 // FINAL COMMAND REVIEW</span>
                <h2 class="text-3xl font-black text-white mt-1">👑 شاشة الفرز والاعتماد النهائي</h2>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
                <!-- التحكم بدرجة النجاح -->
                <div class="flex items-center bg-[#12171f] border border-[#222b38] rounded-xl overflow-hidden h-[42px] shadow-inner w-full sm:w-auto">
                    <span class="px-3 text-xs font-bold text-gray-400 whitespace-nowrap">درجة الاجتياز:</span>
                    <input type="number" id="passScoreInput" value="40" min="0" max="50" oninput="updatePassStatus()" class="w-16 h-full bg-[#0e1218] text-white text-center font-mono font-bold outline-none border-r border-[#222b38] focus:bg-[#1a2029]">
                </div>
                
                <!-- زر التصدير -->
                <button onclick="openExportModal()" class="btn !bg-indigo-600 hover:!bg-indigo-500 !border-indigo-400/50 text-white !py-2.5 h-[42px] whitespace-nowrap w-full sm:w-auto shadow-[0_0_15px_rgba(79,70,229,0.3)]">
                    📄 تصدير البيانات (ناجح/راسب)
                </button>
                
                <!-- البحث -->
                <input type="text" id="searchInput" onkeyup="filterLines()" placeholder="🔍 ابحث بالاسم أو الأيدي..." class="search-input w-full sm:w-64 h-[42px]">
            </div>
        </div>

        <% 
            // فرز تلقائي من الأعلى درجة إلى الأقل
            const sortedApps = applications.sort((a, b) => b.totalScore - a.totalScore); 
        %>

        <% if(sortedApps.length === 0) { %>
            <div class="bg-[#0e1218]/90 border border-dashed border-[#222b38] rounded-2xl p-16 text-center text-gray-500 backdrop-blur-md">
                <span class="text-4xl block mb-3">👑</span>
                <p class="text-lg font-bold">لا يوجد ملفات بانتظار الاعتماد النهائي حالياً.</p>
                <p class="text-xs mt-2">يجب على المدربين إنهاء الرصد في الميدان وإرسال التقييم للقيادة لتظهر الملفات هنا.</p>
            </div>
        <% } else { %>
            <div id="linesContainer" class="flex flex-col gap-4 mb-16">
                <% sortedApps.forEach(app => { %>
                    <!-- الخط العرضي -->
                    <div class="line-item flex flex-col xl:flex-row items-center justify-between bg-[#0e1218]/90 border rounded-2xl p-4 gap-6 transition-all duration-300 hover:bg-[#12171f]" 
                         data-search="<%= app.name %> <%= app.id %> <%= app.copyId %> <%= app.nationalId %>"
                         data-score="<%= app.totalScore %>"
                         data-name="<%= app.name %>"
                         data-nationalid="<%= app.nationalId || 'غير متوفر' %>"
                         data-copyid="<%= app.copyId || 'غير متوفر' %>"
                         data-discordid="<%= app.id %>">
                        
                        <!-- 1. معلومات الطالب الأساسية -->
                        <div class="flex-1 w-full xl:w-auto">
                            <div class="flex items-center gap-3 mb-2">
                                <h3 class="font-black text-xl text-white"><%= app.name %></h3>
                                <span class="status-badge px-2 py-0.5 rounded text-[10px] font-bold tracking-wider uppercase"></span>
                            </div>
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 text-[10px] font-mono text-gray-400 bg-black/30 p-2 rounded-lg border border-white/5">
                                <div>💬 Discord: <strong class="text-gray-200 select-all"><%= app.id %></strong></div>
                                <div>📋 Copy ID: <strong class="text-gray-200 select-all"><%= app.copyId || 'غير متوفر' %></strong></div>
                                <div>🪪 National ID: <strong class="text-gray-200 select-all"><%= app.nationalId || 'غير متوفر' %></strong></div>
                            </div>
                        </div>

                        <!-- 2. تفاصيل الدرجات -->
                        <div class="flex flex-wrap sm:flex-nowrap gap-2 w-full xl:w-auto justify-center bg-[#080a0e] p-2.5 rounded-xl border border-[#1a2029]">
                            <div class="text-center px-4 border-l border-white/5">
                                <span class="block text-[10px] text-gray-500 mb-1">استيقاف</span>
                                <strong class="text-white text-sm font-mono"><%= app.stopsScore %></strong><span class="text-[10px] text-gray-600">/20</span>
                            </div>
                            <div class="text-center px-4 border-l border-white/5">
                                <span class="block text-[10px] text-gray-500 mb-1">تفاوض</span>
                                <strong class="text-white text-sm font-mono"><%= app.negScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                            <div class="text-center px-4 border-l border-white/5">
                                <span class="block text-[10px] text-gray-500 mb-1">عمليات</span>
                                <strong class="text-white text-sm font-mono"><%= app.opsScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                            <div class="text-center px-4">
                                <span class="block text-[10px] text-gray-500 mb-1">أنظمة</span>
                                <strong class="text-white text-sm font-mono"><%= app.genScore %></strong><span class="text-[10px] text-gray-600">/10</span>
                            </div>
                        </div>

                        <!-- 3. النتيجة النهائية -->
                        <div class="text-center min-w-[100px] bg-black/20 p-3 rounded-xl border border-white/5">
                            <span class="text-[10px] text-gray-500 font-bold block mb-1 uppercase tracking-wider">Total</span>
                            <span class="score-display text-3xl font-black font-mono"><%= app.totalScore %></span>
                        </div>

                        <!-- 4. أزرار الاعتماد (التخرج / طي القيد) -->
                        <div class="flex flex-col sm:flex-row gap-2 w-full xl:w-auto border-t xl:border-t-0 xl:border-r border-[#1f2630] pt-3 xl:pt-0 xl:pr-3">
                            <button onclick="makeFinalDecision('<%= app.id %>', 'graduated', this)" class="btn bg-emerald-600 hover:bg-emerald-500 text-white !py-2 text-xs font-bold w-full sm:w-32 shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                                🎓 اعتماد التخرج
                            </button>
                            <button onclick="makeFinalDecision('<%= app.id %>', 'failed', this)" class="btn bg-red-600 hover:bg-red-500 text-white !py-2 text-xs font-bold w-full sm:w-32 shadow-[0_0_15px_rgba(239,68,68,0.3)]">
                                ✖ طي القيد
                            </button>
                        </div>

                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- النافذة المنبثقة لتصدير البيانات -->
    <div id="exportModal" class="fixed inset-0 z-[80] hidden items-center justify-center bg-black/90 backdrop-blur-md p-4">
        <div class="bg-[#0e1218] border border-indigo-500/40 w-full max-w-4xl rounded-2xl shadow-[0_0_50px_rgba(0,0,0,0.8)] flex flex-col max-h-[85vh] animate-modal">
            <div class="bg-[#12171f] px-6 py-4 border-b border-[#222b38] flex justify-between items-center rounded-t-2xl">
                <div class="flex items-center gap-3">
                    <span class="text-2xl">📄</span>
                    <div>
                        <h3 class="text-lg font-black text-white">سجل بيانات التخرج (ناجح/راسب)</h3>
                        <p class="text-xs text-indigo-400 mt-0.5 font-mono" id="exportCountDisplay">يتم الحساب...</p>
                    </div>
                </div>
                <button onclick="closeExportModal()" class="w-8 h-8 rounded-lg bg-[#1a2029] hover:bg-red-600/80 text-gray-400 hover:text-white flex items-center justify-center transition font-bold">✕</button>
            </div>
            
            <div class="p-6 flex-1 overflow-hidden flex flex-col">
                <p class="text-xs text-gray-400 mb-3 font-bold">تم إضافة المنشن <span class="text-indigo-400">&lt;@ID&gt;</span> للنسخ المباشر في الديسكورد.</p>
                <textarea id="exportTextarea" readonly class="w-full flex-1 bg-[#080a0e] border border-[#222b38] rounded-xl p-4 text-sm text-gray-300 font-mono resize-none focus:outline-none focus:border-indigo-500/50 leading-relaxed"></textarea>
            </div>

            <div class="bg-[#12171f] px-6 py-4 border-t border-[#222b38] flex justify-end gap-3 rounded-b-2xl">
                <button onclick="closeExportModal()" class="btn bg-[#1a2029] text-gray-400 hover:text-white border border-[#222b38]">إغلاق</button>
                <button onclick="copyExportData()" class="btn !bg-indigo-600 hover:!bg-indigo-500 text-white px-8">📋 نسخ جميع البيانات</button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        // تشغيل التحديث فور تحميل الصفحة
        document.addEventListener('DOMContentLoaded', () => {
            updatePassStatus();
        });

        // فلترة البحث النصي
        function filterLines() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const lines = document.querySelectorAll('.line-item');
            lines.forEach(line => {
                line.style.display = line.getAttribute('data-search').toLowerCase().includes(input) ? 'flex' : 'none';
            });
        }

        // تحديث حالة النجاح والرسوب وتغيير الألوان ديناميكياً
        function updatePassStatus() {
            const passScore = parseInt(document.getElementById('passScoreInput').value) || 40;
            const lines = document.querySelectorAll('.line-item');

            lines.forEach(line => {
                const score = parseFloat(line.getAttribute('data-score')) || 0;
                const isPassed = score >= passScore;
                
                const scoreDisplay = line.querySelector('.score-display');
                const badge = line.querySelector('.status-badge');

                // مسح الكلاسات القديمة
                line.className = line.className.replace(/border-emerald-500\/50|border-red-500\/50|shadow-\[0_0_15px_rgba\(16,185,129,0\.1\)\]|shadow-\[0_0_15px_rgba\(239,68,68,0\.1\)\]/g, '').trim();
                scoreDisplay.className = scoreDisplay.className.replace(/text-emerald-400|text-red-500/g, '').trim();
                badge.className = badge.className.replace(/bg-emerald-500\/20 text-emerald-400 border-emerald-500\/30|bg-red-500\/20 text-red-400 border-red-500\/30/g, '').trim();

                // تطبيق الكلاسات الجديدة بناءً على النتيجة
                if (isPassed) {
                    line.classList.add('border-emerald-500/50', 'shadow-[0_0_15px_rgba(16,185,129,0.1)]');
                    scoreDisplay.classList.add('text-emerald-400');
                    badge.classList.add('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/30');
                    badge.innerText = '✔ مجتاز للتأهيل';
                } else {
                    line.classList.add('border-red-500/50');
                    scoreDisplay.classList.add('text-red-500');
                    badge.classList.add('bg-red-500/20', 'text-red-400', 'border-red-500/30');
                    badge.innerText = '✖ غير مجتاز';
                }
            });
        }

        // منطق نافذة التصدير الشامل (ناجح + راسب مع منشن الديسكورد)
        function openExportModal() {
            const passScore = parseInt(document.getElementById('passScoreInput').value) || 40;
            const lines = document.querySelectorAll('.line-item');
            
            let passedData = "🎓 === [ قائمة المجتازين للتأهيل ] === 🎓\n\n";
            let failedData = "✖ === [ قائمة غير المجتازين ] === ✖\n\n";
            let passedCount = 0;
            let failedCount = 0;

            lines.forEach(line => {
                const score = parseFloat(line.getAttribute('data-score')) || 0;
                const name = line.getAttribute('data-name');
                const natId = line.getAttribute('data-nationalid');
                const copyId = line.getAttribute('data-copyid');
                const discordId = line.getAttribute('data-discordid');
                
                // إضافة المنشن <@id> للنسخ المباشر في الديسكورد
                const formattedText = `الاسم: ${name} | الرقم الوطني: ${natId} | Copy ID: ${copyId} | Discord: <@${discordId}>\n`;

                if (score >= passScore) {
                    passedCount++;
                    passedData += formattedText;
                } else {
                    failedCount++;
                    failedData += formattedText;
                }
            });

            if (passedCount === 0) passedData += "لا يوجد مجتازين بناءً على درجة الاجتياز المحددة حالياً.\n\n";
            if (failedCount === 0) failedData += "لا يوجد غير مجتازين.\n\n";

            document.getElementById('exportCountDisplay').innerText = `المجتازين: ${passedCount} | غير المجتازين: ${failedCount}`;
            
            // دمج القائمتين مع فاصل بينهم
            document.getElementById('exportTextarea').value = passedData + "\n-----------------------------------------------------------------------\n\n" + failedData;
            
            document.getElementById('exportModal').classList.remove('hidden');
            document.getElementById('exportModal').classList.add('flex');
            document.body.style.overflow = 'hidden';
        }

        function closeExportModal() {
            document.getElementById('exportModal').classList.add('hidden');
            document.getElementById('exportModal').classList.remove('flex');
            document.body.style.overflow = 'auto';
        }

        function copyExportData() {
            const textarea = document.getElementById('exportTextarea');
            textarea.select();
            textarea.setSelectionRange(0, 99999); // للموبايل
            navigator.clipboard.writeText(textarea.value).then(() => {
                const btn = document.querySelector('#exportModal .btn-accept, #exportModal .bg-indigo-600');
                const originalText = btn.innerText;
                btn.innerText = "✔ تم النسخ بنجاح";
                btn.classList.replace('bg-indigo-600', 'bg-emerald-600');
                
                setTimeout(() => {
                    btn.innerText = originalText;
                    btn.classList.replace('bg-emerald-600', 'bg-indigo-600');
                }, 2000);
            });
        }

        // دالة الاعتماد النهائي المطورة مع إشعار الإرسال
        async function makeFinalDecision(id, decision, buttonElement) {
            const isGraduated = decision === 'graduated';
            const confirmMsg = isGraduated ? 
                '🚨 تأكيد: هل أنت متأكد من تخرج هذا المتدرب وإرسال رسالة التهنئة بالخاص؟' : 
                '🚨 تأكيد: هل أنت متأكد من طي قيد هذا المتدرب وإرسال رسالة الرفض بالخاص؟';

            if (!confirm(confirmMsg)) return;

            // 1. تغيير شكل الزر فوراً لمنع الضغط المزدوج
            const originalHtml = buttonElement.innerHTML;
            buttonElement.innerHTML = '<span class="animate-pulse">⏳ جاري الإرسال...</span>';
            buttonElement.disabled = true;

            try {
                const res = await fetch('/api/final-decision', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ id: id, decision: decision }) 
                });
                const data = await res.json();
                
                if (data.success) {
                    // 2. تجميد الزر وتغيير لونه ليعلمك أنه تم الإرسال بنجاح
                    buttonElement.innerHTML = '✅ تم الإرسال';
                    buttonElement.classList.replace('bg-emerald-600', 'bg-gray-600');
                    buttonElement.classList.replace('bg-red-600', 'bg-gray-600');
                    buttonElement.classList.remove('hover:bg-emerald-500', 'hover:bg-red-500');
                    buttonElement.style.cursor = 'not-allowed';
                    
                    // تنبيه نجاح الإرسال
                    alert(isGraduated ? "🎓 تم اعتماد التخرج وإرسال النموذج بنجاح!" : "❌ تم طي القيد وإرسال النموذج بنجاح!");
                } else {
                    alert("⚠️ خطأ في الإرسال: " + data.error);
                    buttonElement.innerHTML = originalHtml;
                    buttonElement.disabled = false;
                }
            } catch (err) {
                alert("⚠️ تعذر الاتصال بالسيرفر. تأكد من اتصالك.");
                buttonElement.innerHTML = originalHtml;
                buttonElement.disabled = false;
            }
        }
    </script>
</body>
</html>