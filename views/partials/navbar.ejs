<header class="bg-[#0b0e12]/95 backdrop-blur-xl border-b border-[#1f2630] sticky top-0 z-50 shadow-[0_10px_30px_rgba(0,0,0,0.8)]">
    <!-- استخدام w-full مع px-8 لدفع العناصر لأقصى الأطراف -->
    <div class="w-full px-6 md:px-10 h-24 flex justify-between items-center">
        
        <!-- أقصى اليمين: الشعار واسم الكلية -->
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-orange-600 to-amber-700 flex items-center justify-center shadow-[0_0_20px_rgba(249,115,22,0.4)] border border-orange-400/30">
                <span class="text-3xl">🛡️</span>
            </div>
            <div>
                <h1 class="text-xl font-black tracking-wider text-white uppercase font-mono">الكلية العسكرية</h1>
                <p class="text-[11px] text-orange-400 font-bold tracking-widest uppercase">نظام إدارة القيادة والتدريب | شرطة جستس</p>
            </div>
        </div>

        <!-- الوسط: القائمة الملاحية (مع إضافة دليل الكلية) -->
        <nav class="hidden xl:flex items-center gap-1.5 bg-[#12171f]/80 p-1.5 rounded-2xl border border-[#222b38] backdrop-blur-md shadow-inner">
            <a href="/dashboard" class="px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 <%= currentPage === 'dashboard' ? 'bg-gradient-to-r from-orange-600 to-amber-600 text-white shadow-[0_0_15px_rgba(249,115,22,0.4)]' : 'text-gray-400 hover:text-white hover:bg-[#1a212c]' %>"> الرئيسية</a>
            <a href="/applications" class="px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 <%= currentPage === 'applications' ? 'bg-gradient-to-r from-orange-600 to-amber-600 text-white shadow-[0_0_15px_rgba(249,115,22,0.4)]' : 'text-gray-400 hover:text-white hover:bg-[#1a212c]' %>"> تقديمات الشرطة</a>
            <a href="/interviews" class="px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 <%= currentPage === 'interviews' ? 'bg-gradient-to-r from-orange-600 to-amber-600 text-white shadow-[0_0_15px_rgba(249,115,22,0.4)]' : 'text-gray-400 hover:text-white hover:bg-[#1a212c]' %>"> المقابلات</a>
            <a href="/preliminary" class="px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 <%= currentPage === 'preliminary' ? 'bg-gradient-to-r from-orange-600 to-amber-600 text-white shadow-[0_0_15px_rgba(249,115,22,0.4)]' : 'text-gray-400 hover:text-white hover:bg-[#1a212c]' %>"> المقبولين مبدئياً</a>
            <a href="/final" class="px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 <%= currentPage === 'final' ? 'bg-gradient-to-r from-orange-600 to-amber-600 text-white shadow-[0_0_15px_rgba(249,115,22,0.4)]' : 'text-gray-400 hover:text-white hover:bg-[#1a212c]' %>"> الرصد النهائي</a>
            <a href="/guide" class="px-5 py-2.5 rounded-xl text-xs font-bold transition-all duration-300 <%= currentPage === 'guide' ? 'bg-gradient-to-r from-blue-600 to-cyan-600 text-white shadow-[0_0_15px_rgba(37,99,235,0.4)]' : 'text-blue-400 hover:text-white hover:bg-[#1a212c]' %>"> دليل الكلية</a>
        </nav>

        <!-- أقصى اليسار: صورة الديسكورد، الاسم، وزر تسجيل الخروج -->
        <div class="flex items-center gap-4">
            <div class="text-left hidden sm:flex flex-col items-end">
                <div class="text-sm font-black text-white tracking-wide"><%= user.username %></div>
                <div class="text-[10px] text-emerald-400 font-mono font-bold tracking-wider">● ضابط الكلية</div>
            </div>
            
            <!-- سحب صورة الديسكورد الخاصة باليوزر -->
            <% const avatarUrl = user.avatar ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png` : 'https://cdn.discordapp.com/embed/avatars/0.png'; %>
            <img src="<%= avatarUrl %>" alt="صورة المستخدم" class="w-12 h-12 rounded-xl border-2 border-[#222b38] shadow-[0_0_15px_rgba(0,0,0,0.5)] object-cover bg-[#161b22]">
            
            <div class="h-8 w-px bg-[#222b38] mx-1"></div>
            
            <a href="/logout" title="تسجيل الخروج" class="w-12 h-12 rounded-xl bg-red-500/10 hover:bg-red-600 text-red-500 hover:text-white border border-red-500/20 flex items-center justify-center transition-all shadow-lg group">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:rotate-12 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
            </a>
        </div>
    </div>
</header>