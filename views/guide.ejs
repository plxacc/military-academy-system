<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>دليل الكلية وبنك الأسئلة | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col bg-[#05070a] selection:bg-blue-500 selection:text-white font-sans">
    <%- include('partials/navbar') %>

    <main class="max-w-[90rem] mx-auto px-6 py-12 flex-1 w-full">
        
        <!-- الهيدر الرئيسي للدليل -->
        <div class="relative rounded-[2.5rem] bg-[#0d1117] border border-[#1f2630] p-10 md:p-12 mb-12 shadow-2xl overflow-hidden">
            <div class="absolute top-0 left-0 w-1/3 h-full bg-gradient-to-r from-blue-900/20 to-transparent opacity-50"></div>
            <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                <div>
                    <span class="inline-block bg-blue-500/10 text-blue-400 border border-blue-500/20 text-xs font-mono font-bold px-4 py-1.5 rounded-full uppercase tracking-widest mb-4">
                        OFFICIAL ACADEMY MANUAL
                    </span>
                    <h2 class="text-3xl md:text-4xl font-black text-white mb-2 tracking-wide">دليل النظام العسكري الشامل</h2>
                    <p class="text-sm text-gray-400 max-w-2xl leading-relaxed">
                        المرجع الرسمي للإجراءات، الرتب، المناهج الميدانية، وبنك الأسئلة المخصص للمدربين وقيادة الكلية.
                    </p>
                </div>
            </div>
        </div>

        <!-- 1. مراحل عمل الكلية (Timeline) -->
        <div class="mb-16">
            <div class="flex items-center gap-4 mb-8">
                <h3 class="text-2xl font-black text-white uppercase tracking-widest">مسار القبول والتأهيل</h3>
                <div class="flex-1 h-px bg-gradient-to-l from-[#1f2630] to-transparent"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-2xl p-6 relative overflow-hidden group hover:border-orange-500/50 transition-colors">
                    <div class="absolute right-0 top-0 w-1.5 h-full bg-orange-500/70"></div>
                    <div class="text-orange-400 font-black text-5xl mb-4 opacity-20 group-hover:opacity-40 transition-opacity">01</div>
                    <h4 class="text-xl font-black text-white mb-2">فتح باب التقديم</h4>
                    <p class="text-xs text-orange-400 font-mono mb-4 border-b border-white/5 pb-3">التاريخ المجدول: 15 / 08 / 2026</p>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        استقبال الطلبات إلكترونياً عبر النظام، وتدقيق البيانات الأولية للمتقدمين من قبل مشرفي القبول للتأكد من مطابقة الشروط.
                    </p>
                </div>

                <div class="bg-[#0d1117] border border-[#1f2630] rounded-2xl p-6 relative overflow-hidden group hover:border-amber-500/50 transition-colors">
                    <div class="absolute right-0 top-0 w-1.5 h-full bg-amber-500/70"></div>
                    <div class="text-amber-400 font-black text-5xl mb-4 opacity-20 group-hover:opacity-40 transition-opacity">02</div>
                    <h4 class="text-xl font-black text-white mb-2">المقابلات الشخصية</h4>
                    <p class="text-xs text-amber-400 font-mono mb-4 border-b border-white/5 pb-3">التاريخ المجدول: 20 / 08 / 2026</p>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        تقييم السمات الشخصية، سرعة البديهة، والقدرة على الانضباط العسكري من خلال لجان الفرز المباشرة.
                    </p>
                </div>

                <div class="bg-[#0d1117] border border-[#1f2630] rounded-2xl p-6 relative overflow-hidden group hover:border-emerald-500/50 transition-colors">
                    <div class="absolute right-0 top-0 w-1.5 h-full bg-emerald-500/70"></div>
                    <div class="text-emerald-500 font-black text-5xl mb-4 opacity-20 group-hover:opacity-40 transition-opacity">03</div>
                    <h4 class="text-xl font-black text-white mb-2">التدريب الميداني</h4>
                    <p class="text-xs text-emerald-400 font-mono mb-4 border-b border-white/5 pb-3">التاريخ المجدول: 25 / 08 / 2026</p>
                    <p class="text-sm text-gray-400 leading-relaxed">
                        دخول المتدربين للميدان الفعلي وتطبيق السيناريوهات الحية تحت إشراف طاقم التدريب لرصد الدرجات النهائية بدقة.
                    </p>
                </div>
            </div>
        </div>

        <!-- 2. سلم الرتب العسكرية -->
        <div class="mb-16">
            <div class="flex items-center gap-4 mb-8">
                <h3 class="text-2xl font-black text-white uppercase tracking-widest">التسلسل الهرمي للرتب العسكرية</h3>
                <div class="flex-1 h-px bg-gradient-to-l from-[#1f2630] to-transparent"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- الأفراد -->
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-3xl p-8">
                    <h4 class="text-lg font-black text-gray-300 mb-6 text-center bg-[#161b22] py-2 rounded-xl border border-[#222b38]">أفراد وضباط صف</h4>
                    <div class="flex flex-wrap gap-3 justify-center">
                        <span class="px-5 py-2.5 bg-[#05070a] border border-[#1f2630] rounded-lg text-sm font-bold text-gray-400">جندي</span>
                        <span class="px-5 py-2.5 bg-[#05070a] border border-[#1f2630] rounded-lg text-sm font-bold text-gray-400">جندي أول</span>
                        <span class="px-5 py-2.5 bg-[#05070a] border border-[#1f2630] rounded-lg text-sm font-bold text-gray-300">عريف</span>
                        <span class="px-5 py-2.5 bg-[#05070a] border border-[#1f2630] rounded-lg text-sm font-bold text-gray-300">وكيل رقيب</span>
                        <span class="px-5 py-2.5 bg-[#12171f] border border-blue-900/30 rounded-lg text-sm font-bold text-blue-400">رقيب</span>
                        <span class="px-5 py-2.5 bg-[#12171f] border border-blue-900/50 rounded-lg text-sm font-bold text-blue-300">رقيب أول</span>
                        <span class="px-6 py-2.5 bg-blue-900/20 border border-blue-500/30 rounded-lg text-sm font-black text-blue-200 shadow-[0_0_15px_rgba(37,99,235,0.1)] w-full text-center mt-2">رئيس رقباء</span>
                    </div>
                </div>

                <!-- الضباط -->
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-3xl p-8">
                    <h4 class="text-lg font-black text-amber-500/80 mb-6 text-center bg-amber-900/10 py-2 rounded-xl border border-amber-900/20">الضباط والقيادة</h4>
                    <div class="flex flex-wrap gap-3 justify-center">
                        <span class="px-5 py-2.5 bg-[#05070a] border border-amber-900/30 rounded-lg text-sm font-bold text-amber-500/70">ملازم</span>
                        <span class="px-5 py-2.5 bg-[#05070a] border border-amber-900/40 rounded-lg text-sm font-bold text-amber-500/80">ملازم أول</span>
                        <span class="px-5 py-2.5 bg-[#05070a] border border-amber-900/50 rounded-lg text-sm font-bold text-amber-500/90">نقيب</span>
                        <span class="px-5 py-2.5 bg-[#12171f] border border-amber-700/50 rounded-lg text-sm font-bold text-amber-400">رائد</span>
                        <span class="px-5 py-2.5 bg-[#12171f] border border-amber-600/50 rounded-lg text-sm font-bold text-amber-300">مقدم</span>
                        <span class="px-5 py-2.5 bg-[#12171f] border border-amber-500/50 rounded-lg text-sm font-bold text-amber-200">عقيد</span>
                        <span class="px-6 py-2.5 bg-amber-900/20 border border-amber-500/40 rounded-lg text-sm font-black text-amber-100 shadow-[0_0_15px_rgba(245,158,11,0.1)] w-full sm:w-auto mt-2">عميد</span>
                        <span class="px-6 py-2.5 bg-amber-900/30 border border-amber-500/60 rounded-lg text-sm font-black text-amber-100 shadow-[0_0_15px_rgba(245,158,11,0.2)] w-full sm:w-auto mt-2">لواء</span>
                        <span class="px-8 py-3 bg-gradient-to-r from-amber-600 to-amber-800 border border-amber-400 rounded-lg text-base font-black text-white shadow-[0_0_20px_rgba(245,158,11,0.4)] w-full text-center mt-2 tracking-widest">فريق</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. الأقسام والمناهج الميدانية -->
        <div class="mb-16">
            <div class="flex items-center gap-4 mb-8">
                <h3 class="text-2xl font-black text-white uppercase tracking-widest">تخصصات التدريب الميداني</h3>
                <div class="flex-1 h-px bg-gradient-to-l from-[#1f2630] to-transparent"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- قسم الاستيقافات -->
                <div class="bg-[#0d1117] border border-teal-900/40 rounded-2xl p-6 flex flex-col h-full hover:border-teal-500/50 transition-all">
                    <div class="flex items-center gap-3 mb-4 border-b border-white/5 pb-4">
                        <span class="bg-teal-500/10 text-teal-400 p-3 rounded-xl border border-teal-500/20 text-2xl">🚓</span>
                        <h4 class="text-xl font-black text-white">الاستيقافات الميدانية</h4>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed mb-6 flex-1">
                        تطوير مهارات الفرد في إيقاف المركبات والمشتبه بهم بطرق آمنة وقانونية، والسيطرة التامة على محيط الحدث.
                    </p>
                    <ul class="space-y-3 text-xs font-mono text-gray-300 bg-[#05070a] p-4 rounded-xl border border-[#1f2630]">
                        <li class="flex items-center gap-2"><span class="text-teal-500">▪</span> الاستيقاف المروري الروتيني</li>
                        <li class="flex items-center gap-2"><span class="text-teal-500">▪</span> الاستيقاف الجنائي عالي الخطورة</li>
                        <li class="flex items-center gap-2"><span class="text-teal-500">▪</span> الاستيقاف الإجباري (التكتيكي)</li>
                        <li class="flex items-center gap-2"><span class="text-teal-500">▪</span> حماية الزميل والتمركز الصحيح</li>
                    </ul>
                </div>

                <!-- قسم التفاوض -->
                <div class="bg-[#0d1117] border border-amber-900/40 rounded-2xl p-6 flex flex-col h-full hover:border-amber-500/50 transition-all">
                    <div class="flex items-center gap-3 mb-4 border-b border-white/5 pb-4">
                        <span class="bg-amber-500/10 text-amber-400 p-3 rounded-xl border border-amber-500/20 text-2xl">🗣️</span>
                        <h4 class="text-xl font-black text-white">التفاوض الإستراتيجي</h4>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed mb-6 flex-1">
                        علم نفس الجريمة وفن السيطرة اللفظية على المواقف المتأزمة لتقليل الخسائر البشرية وإنهاء الاحتجاز سلمياً.
                    </p>
                    <ul class="space-y-3 text-xs font-mono text-gray-300 bg-[#05070a] p-4 rounded-xl border border-[#1f2630]">
                        <li class="flex items-center gap-2"><span class="text-amber-500">▪</span> استراتيجيات التعامل مع محتجزي الرهائن</li>
                        <li class="flex items-center gap-2"><span class="text-amber-500">▪</span> قراءة لغة الجسد للمشتبه بهم</li>
                        <li class="flex items-center gap-2"><span class="text-amber-500">▪</span> التفاوض تحت الضغط العالي</li>
                        <li class="flex items-center gap-2"><span class="text-amber-500">▪</span> جمع المعلومات أثناء الحوار</li>
                    </ul>
                </div>

                <!-- قسم العمليات -->
                <div class="bg-[#0d1117] border border-purple-900/40 rounded-2xl p-6 flex flex-col h-full hover:border-purple-500/50 transition-all">
                    <div class="flex items-center gap-3 mb-4 border-b border-white/5 pb-4">
                        <span class="bg-purple-500/10 text-purple-400 p-3 rounded-xl border border-purple-500/20 text-2xl">⚙️</span>
                        <h4 class="text-xl font-black text-white">إدارة العمليات التكتيكية</h4>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed mb-6 flex-1">
                        تدريب الضباط على التخطيط، المداهمات، الاتصال اللاسلكي، وإدارة مسرح الجريمة بشكل احترافي.
                    </p>
                    <ul class="space-y-3 text-xs font-mono text-gray-300 bg-[#05070a] p-4 rounded-xl border border-[#1f2630]">
                        <li class="flex items-center gap-2"><span class="text-purple-500">▪</span> أبجديات الراديو والاتصال المركزي</li>
                        <li class="flex items-center gap-2"><span class="text-purple-500">▪</span> تكتيكات المداهمة والاقتحام</li>
                        <li class="flex items-center gap-2"><span class="text-purple-500">▪</span> القيادة الميدانية وتوزيع المهام</li>
                        <li class="flex items-center gap-2"><span class="text-purple-500">▪</span> التعامل مع البلاغات المزدوجة</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- 4. بنك الأسئلة (القسم البرمجي القديم) -->
        <div class="mt-20">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 mb-8 border-b border-[#1f2630] pb-5">
                <div>
                    <h3 class="text-2xl font-black text-white tracking-widest">بنك الأسئلة الميدانية</h3>
                    <p class="text-xs text-gray-500 mt-1 font-mono">قاعدة بيانات الأسئلة المرتبطة بنظام التقييم الفعلي</p>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto items-center">
                    <input type="text" id="searchInput" onkeyup="filterQuestions()" placeholder="🔍 ابحث عن سؤال..." class="search-input sm:w-64">
                    <button onclick="openAddModal()" class="btn btn-accept whitespace-nowrap !py-2.5">
                        ➕ أضف سؤالاً جديداً
                    </button>
                </div>
            </div>

            <% if(questions.length === 0) { %>
                <div class="bg-[#0e1218]/90 border border-dashed border-[#222b38] rounded-2xl p-16 text-center text-gray-500 backdrop-blur-md">
                    <span class="text-4xl block mb-3">📝</span>
                    <p class="text-lg font-bold">لا توجد أسئلة مضافة في تخصصك الحالي حتى الآن.</p>
                </div>
            <% } else { %>
                <div id="questionsContainer" class="flex flex-col gap-3">
                    <% questions.forEach(q => { 
                        let sectionName = '';
                        let sectionColor = '';
                        if(q.section === 'stops') { sectionName = 'استيقافات'; sectionColor = 'text-teal-400 bg-teal-500/10 border-teal-500/20'; }
                        else if(q.section === 'neg') { sectionName = 'تفاوض'; sectionColor = 'text-amber-400 bg-amber-500/10 border-amber-500/20'; }
                        else if(q.section === 'ops') { sectionName = 'عمليات'; sectionColor = 'text-purple-400 bg-purple-500/10 border-purple-500/20'; }
                        else { sectionName = 'أنظمة عامة'; sectionColor = 'text-blue-400 bg-blue-500/10 border-blue-500/20'; }
                    %>
                        <div class="question-line flex flex-col md:flex-row items-center justify-between bg-[#0d1117] border border-[#1f2630] rounded-xl p-4 gap-4 hover:bg-[#121820] transition shadow-sm" data-search="<%= q.text %>">
                            
                            <div class="flex items-center gap-4 w-full md:flex-1">
                                <span class="badge <%= sectionColor %> shrink-0 min-w-[90px] text-center"><%= sectionName %></span>
                                <p class="text-sm font-bold text-gray-200 leading-relaxed"><%= q.text %></p>
                            </div>

                            <div class="flex items-center justify-between md:justify-end gap-6 w-full md:w-auto border-t md:border-t-0 pt-3 md:pt-0 border-white/5">
                                <div class="text-xs font-mono text-gray-500">
                                    المُضيف: <strong class="text-gray-300"><%= q.addedBy %></strong>
                                </div>
                                <div class="bg-[#05070a] px-3 py-1.5 rounded-lg border border-[#1f2630] text-xs font-mono text-center min-w-[70px]">
                                    <span class="text-gray-400">الدرجة:</span> <strong class="text-white"><%= q.maxScore %></strong>
                                </div>
                                
                                <% if(isSupervisor) { %>
                                    <button onclick="deleteQuestion('<%= q.id %>')" class="w-8 h-8 rounded-lg bg-red-500/10 text-red-500 hover:bg-red-600 hover:text-white flex items-center justify-center transition border border-red-500/20 shrink-0" title="حذف السؤال">✕</button>
                                <% } %>
                            </div>

                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </main>

    <!-- النافذة المنبثقة لإضافة الأسئلة -->
    <div id="addQuestionModal" class="fixed inset-0 z-[70] hidden items-center justify-center bg-black/90 backdrop-blur-md p-4">
        <div class="bg-[#0e1218] border border-blue-500/40 w-full max-w-md rounded-2xl shadow-2xl p-6 animate-modal">
            <h3 class="text-xl font-black text-white mb-2">➕ إضافة سؤال تخصصي</h3>
            <p class="text-xs text-gray-400 mb-6">سيتم تسجيل السؤال في قاعدة البيانات للتقييم الميداني.</p>
            
            <div class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-300">القسم المخصص للسؤال:</label>
                    <select id="qSection" class="search-input mt-1 w-full bg-[#12171f]">
                        <% if(user.permissions.canGradeStops || isSupervisor) { %><option value="stops">🚓 قسم الاستيقافات</option><% } %>
                        <% if(user.permissions.canGradeNeg || isSupervisor) { %><option value="neg">🗣️ قسم التفاوض الإستراتيجي</option><% } %>
                        <% if(user.permissions.canGradeOps || isSupervisor) { %><option value="ops">⚙️ قسم إدارة العمليات الميدانية</option><% } %>
                        <% if(user.permissions.canGradeGen || isSupervisor) { %><option value="gen">❓ قسم الأنظمة العسكرية العامة</option><% } %>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-300">نص السؤال:</label>
                    <textarea id="qText" class="search-input mt-1 w-full h-24 p-3 resize-none" placeholder="اكتب نص السؤال العسكري هنا..."></textarea>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-300">الدرجة المستحقة:</label>
                    <input type="number" id="qScore" class="search-input mt-1 w-full" placeholder="مثال: 2" min="1">
                </div>
            </div>

            <div class="flex gap-3 mt-8">
                <button onclick="closeModal()" class="btn bg-[#1a2029] text-gray-400 hover:text-white border border-[#222b38]">إلغاء</button>
                <button onclick="submitNewQuestion()" id="confirmAddBtn" class="btn btn-accept !bg-gradient-to-r !from-blue-600 !to-indigo-700">✔ اعتماد وحفظ</button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        function filterQuestions() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const lines = document.querySelectorAll('.question-line');
            lines.forEach(line => {
                line.style.display = line.getAttribute('data-search').toLowerCase().includes(input) ? 'flex' : 'none';
            });
        }

        function openAddModal() {
            document.getElementById('qText').value = '';
            document.getElementById('qScore').value = '';
            document.getElementById('addQuestionModal').classList.remove('hidden');
            document.getElementById('addQuestionModal').classList.add('flex');
        }

        function closeModal() {
            document.getElementById('addQuestionModal').classList.add('hidden');
            document.getElementById('addQuestionModal').classList.remove('flex');
        }

        async function submitNewQuestion() {
            const section = document.getElementById('qSection').value;
            const text = document.getElementById('qText').value.trim();
            const maxScore = document.getElementById('qScore').value.trim();

            if (!text || !maxScore) {
                alert("يرجى تعبئة نص السؤال والدرجة المستحقة أولاً!");
                return;
            }

            const btn = document.getElementById('confirmAddBtn');
            btn.innerText = "⏳ جاري الحفظ..."; btn.disabled = true;

            try {
                const response = await fetch('/api/guide/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ section, text, maxScore })
                });
                const result = await response.json();
                if (result.success) location.reload();
                else { alert('⚠️ خطأ: ' + result.error); btn.disabled = false; btn.innerText = "✔ اعتماد وحفظ"; }
            } catch (err) { alert('⚠️ تعذر الاتصال بالسيرفر.'); btn.disabled = false; }
        }

        async function deleteQuestion(id) {
            if (confirm("🚨 هل أنت متأكد من حذف هذا السؤال نهائياً؟")) {
                const response = await fetch('/api/guide/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                const result = await response.json();
                if (result.success) location.reload();
                else alert('⚠️ خطأ: ' + result.error);
            }
        }
    </script>
</body>
</html>