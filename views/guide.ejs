<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>دليل الكلية وبنك الأسئلة | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col selection:bg-blue-500 selection:text-white">
    <%- include('partials/navbar') %>

    <main class="max-w-7xl mx-auto px-6 py-10 flex-1 w-full">
        <!-- الهيدر وأزرار التحكم -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 mb-8 border-b border-[#1f2630] pb-5">
            <div>
                <span class="text-blue-400 font-mono text-xs font-bold uppercase tracking-widest">ACADEMY MANUAL // QUESTION BANK</span>
                <h2 class="text-3xl font-black text-white mt-1">📖 دليل الكلية وبنك الأسئلة الميدانية</h2>
            </div>
            
            <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto items-center">
                <input type="text" id="searchInput" onkeyup="filterQuestions()" placeholder="🔍 ابحث عن سؤال..." class="search-input sm:w-64">
                
                <!-- زر إضافة سؤال ذكي يفتح النافذة المنبثقة المخصصة -->
                <button onclick="openAddModal()" class="btn btn-accept whitespace-nowrap !py-2.5">
                    ➕ أضف سؤالاً تخصصياً جديداً
                </button>
            </div>
        </div>

        <% if(questions.length === 0) { %>
            <div class="bg-[#0e1218]/90 border border-dashed border-[#222b38] rounded-2xl p-16 text-center text-gray-500 backdrop-blur-md">
                <span class="text-4xl block mb-3">📝</span>
                <p class="text-lg font-bold">لا توجد أسئلة مضافة في تخصصك الحالي حتى الآن.</p>
            </div>
        <% } else { %>
            <!-- عرض بنك الأسئلة على شكل أسطر عسكرية منظمة -->
            <div id="questionsContainer" class="flex flex-col gap-3">
                <% questions.forEach(q => { 
                    let sectionName = '';
                    let sectionColor = '';
                    if(q.section === 'stops') { sectionName = '🚓 استيقافات'; sectionColor = 'text-teal-400 bg-teal-500/10 border-teal-500/20'; }
                    else if(q.section === 'neg') { sectionName = '🗣️ تفاوض'; sectionColor = 'text-amber-400 bg-amber-500/10 border-amber-500/20'; }
                    else if(q.section === 'ops') { sectionName = '⚙️ عمليات'; sectionColor = 'text-purple-400 bg-purple-500/10 border-purple-500/20'; }
                    else { sectionName = '❓ أنظمة عامة'; sectionColor = 'text-blue-400 bg-blue-500/10 border-blue-500/20'; }
                %>
                    <div class="question-line flex flex-col md:flex-row items-center justify-between bg-[#0e1218]/90 border border-[#222b38] rounded-xl p-4 gap-4 hover:border-blue-500/30 transition shadow-md" data-search="<%= q.text %>">
                        
                        <!-- القسم ونص السؤال -->
                        <div class="flex items-center gap-4 w-full md:flex-1">
                            <span class="badge <%= sectionColor %> shrink-0 min-w-[90px] text-center"><%= sectionName %></span>
                            <p class="text-sm font-bold text-gray-200 leading-relaxed"><%= q.text %></p>
                        </div>

                        <!-- الدرجة المحددة والمضيف وصلاحية الحذف -->
                        <div class="flex items-center justify-between md:justify-end gap-6 w-full md:w-auto border-t md:border-t-0 pt-2 md:pt-0 border-white/5">
                            <div class="text-xs font-mono text-gray-500">
                                بواسطة: <strong class="text-gray-300"><%= q.addedBy %></strong>
                            </div>
                            <div class="bg-black/40 px-3 py-1 rounded-lg border border-white/5 text-xs font-mono text-center min-w-[70px]">
                                <span class="text-gray-400">الدرجة:</span> <strong class="text-white"><%= q.maxScore %></strong>
                            </div>
                            
                            <!-- خيار الحذف يظهر فقط للمشرفين والقيادة لمنع تخريب الأسئلة -->
                            <% if(isSupervisor) { %>
                                <button onclick="deleteQuestion('<%= q.id %>')" class="w-8 h-8 rounded-lg bg-red-500/10 text-red-500 hover:bg-red-600 hover:text-white flex items-center justify-center transition border border-red-500/20 shrink-0" title="حذف السؤال من البنك">✕</button>
                            <% } %>
                        </div>

                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- 🌟 النافذة المنبثقة المخصصة لإضافة الأسئلة (Custom Modal) 🌟 -->
    <div id="addQuestionModal" class="fixed inset-0 z-[70] hidden items-center justify-center bg-black/90 backdrop-blur-md p-4">
        <div class="bg-[#0e1218] border border-blue-500/40 w-full max-w-md rounded-2xl shadow-2xl p-6 anonymity animate-modal">
            <h3 class="text-xl font-black text-white mb-2">➕ إضافة سؤال تخصصي جديد</h3>
            <p class="text-xs text-gray-400 mb-6">سيتم تسجيل هذا السؤال وحفظه في شيت الدليل لإدراجه في رصد الميدان تلقائياً.</p>
            
            <div class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-300">حدد قسم التخصص المخصص للسؤال:</label>
                    <select id="qSection" class="search-input mt-1 w-full bg-[#12171f]">
                        <% if(user.permissions.canGradeStops || isSupervisor) { %><option value="stops">🚓 قسم الاستيقافات</option><% } %>
                        <% if(user.permissions.canGradeNeg || isSupervisor) { %><option value="neg">🗣️ قسم التفاوض الإستراتيجي</option><% } %>
                        <% if(user.permissions.canGradeOps || isSupervisor) { %><option value="ops">⚙️ قسم إدارة العمليات الميدانية</option><% } %>
                        <% if(user.permissions.canGradeGen || isSupervisor) { %><option value="gen">❓ قسم الأنظمة العسكرية العامة</option><% } %>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-300">نص السؤال التقييمي:</label>
                    <textarea id="qText" class="search-input mt-1 w-full h-24 p-3 resize-none" placeholder="اكتب نص السؤال العسكري هنا..."></textarea>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-300">الحد الأقصى لدرجة السؤال:</label>
                    <input type="number" id="qScore" class="search-input mt-1 w-full" placeholder="مثال: 2" min="1">
                </div>
            </div>

            <div class="flex gap-3 mt-8">
                <button onclick="closeAddModal()" class="btn bg-[#1a2029] text-gray-400 hover:text-white border border-[#222b38]">إلغاء</button>
                <button onclick="submitNewQuestion()" id="confirmAddBtn" class="btn btn-accept !bg-gradient-to-r !from-blue-600 !to-indigo-700">✔ اعتماد وحفظ بالدليل</button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        function filterQuestions() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const lines = document.querySelectorAll('.question-line');
            lines.forEach(line => {
                line.style.display = line.getAttribute('data-search').toLowerCase().includes(input) ? 'flex' : 'none';
            });
        }

        function openAddModal() {
            document.getElementById('qText').value = '';
            document.getElementById('qScore').value = '';
            document.getElementById('addQuestionModal').classList.remove('hidden');
            document.getElementById('addQuestionModal').classList.add('flex');
        }

        function closeModal(id = 'addQuestionModal') {
            document.getElementById('addQuestionModal').classList.add('hidden');
            document.getElementById('addQuestionModal').classList.remove('flex');
        }

        async function submitNewQuestion() {
            const section = document.getElementById('qSection').value;
            const text = document.getElementById('qText').value.trim();
            const maxScore = document.getElementById('qScore').value.trim();

            if (!text || !maxScore) {
                alert("يرجى تعبئة نص السؤال والدرجة المستحقة أولاً!");
                return;
            }

            const btn = document.getElementById('confirmAddBtn');
            btn.innerText = "⏳ جاري الحفظ..."; btn.disabled = true;

            try {
                const response = await fetch('/api/guide/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ section, text, maxScore })
                });
                const result = await response.json();
                if (result.success) location.reload();
                else { alert('⚠️ خطأ: ' + result.error); btn.disabled = false; btn.innerText = "✔ اعتماد وحفظ بالدليل"; }
            } catch (err) { alert('⚠️ تعذر الاتصال بالسيرفر.'); btn.disabled = false; }
        }

        async function deleteQuestion(id) {
            if (confirm("🚨 هل أنت متأكد من حذف هذا السؤال نهائياً من دليل الكلية؟")) {
                const response = await fetch('/api/guide/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                const result = await response.json();
                if (result.success) location.reload();
                else alert('⚠️ خطأ: ' + result.error);
            }
        }
    </script>
</body>
</html>