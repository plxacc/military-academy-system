<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>دليل الكلية وبنك الأسئلة | الكلية العسكرية</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* تأثيرات البطاقات العسكرية */
        .rank-card {
            background: linear-gradient(145deg, #12171f, #0a0d12);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), 0 4px 10px rgba(0,0,0,0.5);
            transition: all 0.3s ease;
        }
        .rank-card:hover {
            transform: translateY(-5px);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 8px 20px rgba(0,0,0,0.8);
        }
        /* حركة السهم عند الطي */
        .toggle-icon { transition: transform 0.3s ease; }
        .is-open .toggle-icon { transform: rotate(180deg); }
    </style>
</head>
<body class="min-h-screen flex flex-col bg-[#05070a] selection:bg-blue-500 selection:text-white font-sans">
    <%- include('partials/navbar') %>

    <main class="max-w-[90rem] mx-auto px-6 py-12 flex-1 w-full">
        
        <!-- الهيدر الرئيسي للدليل -->
        <div class="relative rounded-[2.5rem] bg-[#0d1117] border border-[#1f2630] p-10 md:p-12 mb-12 shadow-2xl overflow-hidden">
            <div class="absolute top-0 left-0 w-1/3 h-full bg-gradient-to-r from-blue-900/20 to-transparent opacity-50"></div>
            <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                <div>
                    <span class="inline-block bg-blue-500/10 text-blue-400 border border-blue-500/20 text-xs font-mono font-bold px-4 py-1.5 rounded-full uppercase tracking-widest mb-4">
                        OFFICIAL ACADEMY MANUAL
                    </span>
                    <h2 class="text-3xl md:text-4xl font-black text-white mb-2 tracking-wide">دليل النظام العسكري الشامل</h2>
                    <p class="text-sm text-gray-400 max-w-2xl leading-relaxed">
                        المرجع الرسمي للإجراءات، الرتب، المناهج الميدانية، وبنك الأسئلة المخصص للمدربين وقيادة الكلية.
                    </p>
                </div>
            </div>
        </div>

        <!-- 1. مراحل عمل الكلية (Timeline) -->
        <div class="mb-16">
            <div class="flex items-center gap-4 mb-8">
                <h3 class="text-2xl font-black text-white uppercase tracking-widest">مسار القبول والتأهيل</h3>
                <div class="flex-1 h-px bg-gradient-to-l from-[#1f2630] to-transparent"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-2xl p-6 relative overflow-hidden group hover:border-orange-500/50 transition-colors">
                    <div class="absolute right-0 top-0 w-1.5 h-full bg-orange-500/70"></div>
                    <div class="text-orange-400 font-black text-5xl mb-4 opacity-20 group-hover:opacity-40 transition-opacity">01</div>
                    <h4 class="text-xl font-black text-white mb-2">فتح باب التقديم</h4>
                    <p class="text-xs text-orange-400 font-mono mb-4 border-b border-white/5 pb-3">التاريخ المجدول: 15 / 08 / 2026</p>
                    <p class="text-sm text-gray-400 leading-relaxed">استقبال الطلبات إلكترونياً وتدقيق البيانات الأولية للمتقدمين.</p>
                </div>
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-2xl p-6 relative overflow-hidden group hover:border-amber-500/50 transition-colors">
                    <div class="absolute right-0 top-0 w-1.5 h-full bg-amber-500/70"></div>
                    <div class="text-amber-400 font-black text-5xl mb-4 opacity-20 group-hover:opacity-40 transition-opacity">02</div>
                    <h4 class="text-xl font-black text-white mb-2">التدريب النظري</h4>
                    <p class="text-xs text-amber-400 font-mono mb-4 border-b border-white/5 pb-3">التاريخ المجدول: 18 / 08 / 2026</p>
                    <p class="text-sm text-gray-400 leading-relaxed">التعليم والتدريب النظري للمتدربين.</p>
                </div>
                <div class="bg-[#0d1117] border border-[#1f2630] rounded-2xl p-6 relative overflow-hidden group hover:border-emerald-500/50 transition-colors">
                    <div class="absolute right-0 top-0 w-1.5 h-full bg-emerald-500/70"></div>
                    <div class="text-emerald-500 font-black text-5xl mb-4 opacity-20 group-hover:opacity-40 transition-opacity">03</div>
                    <h4 class="text-xl font-black text-white mb-2">التدريب الميداني</h4>
                    <p class="text-xs text-emerald-400 font-mono mb-4 border-b border-white/5 pb-3">التاريخ المجدول: 19 / 08 / 2026</p>
                    <p class="text-sm text-gray-400 leading-relaxed">دخول الميدان لتطبيق السيناريوهات الحية ورصد الدرجات النهائية بدقة.</p>
                </div>
            </div>
        </div>
 
        <!-- 2. سلم الرتب العسكرية (التصميم الفخم مع الصور) -->
        <div class="mb-20">
            <div class="flex items-center gap-4 mb-8">
                <h3 class="text-2xl font-black text-white uppercase tracking-widest">لوحة الشرف: التسلسل الهرمي للرتب</h3>
                <div class="flex-1 h-px bg-gradient-to-l from-[#1f2630] to-transparent"></div>
            </div>

            <!-- قطاع الأفراد (Enlisted) -->
            <div class="bg-[#0a0d12] border border-[#1f2630] rounded-[2rem] p-8 relative overflow-hidden shadow-lg mb-8">
                <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-l from-slate-500 to-transparent"></div>
                <div class="flex flex-col items-center mb-8 text-center">
                    <span class="text-4xl mb-2"></span>
                    <h4 class="text-2xl font-black text-white">أفراد وضباط صف</h4>
                    <p class="text-xs text-slate-400 font-mono mt-1 tracking-widest">ENLISTED RANKS</p>
                </div>
                
                <div class="flex flex-wrap justify-center gap-4 md:gap-6">
                    <!-- كرت رتبة مصور -->
                    <div class="rank-card border border-slate-700/50 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/jundi.png" alt="جندي" class="w-16 h-16 object-contain mb-3 drop-shadow-md">
                        <h5 class="text-slate-300 font-bold text-sm">جندي</h5>
                    </div>
                    <div class="rank-card border border-slate-700/50 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/jundi_awwal.png" alt="جندي أول" class="w-16 h-16 object-contain mb-3 drop-shadow-md">
                        <h5 class="text-slate-300 font-bold text-sm">جندي أول</h5>
                    </div>
                    <div class="rank-card border border-slate-600/50 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/areef.png" alt="عريف" class="w-16 h-16 object-contain mb-3 drop-shadow-md">
                        <h5 class="text-slate-200 font-bold text-sm">عريف</h5>
                    </div>
                    <div class="rank-card border border-blue-900/40 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/wakeel_raqeeb.png" alt="وكيل رقيب" class="w-16 h-16 object-contain mb-3 drop-shadow-lg">
                        <h5 class="text-blue-300 font-bold text-sm">وكيل رقيب</h5>
                    </div>
                    <div class="rank-card border border-blue-800/40 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/raqeeb.png" alt="رقيب" class="w-16 h-16 object-contain mb-3 drop-shadow-lg">
                        <h5 class="text-blue-400 font-bold text-sm">رقيب</h5>
                    </div>
                    <div class="rank-card border border-blue-700/40 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/raqeeb_awwal.png" alt="رقيب أول" class="w-16 h-16 object-contain mb-3 drop-shadow-xl">
                        <h5 class="text-blue-500 font-black text-sm">رقيب أول</h5>
                    </div>
                    <div class="rank-card border border-indigo-500/40 rounded-2xl p-4 w-40 flex flex-col items-center text-center shadow-[0_0_15px_rgba(99,102,241,0.15)] relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-full h-1 bg-indigo-500"></div>
                        <img src="/images/ranks/raees_ruqaba.png" alt="رئيس رقباء" class="w-20 h-20 object-contain mb-3 drop-shadow-2xl">
                        <h5 class="text-indigo-400 font-black text-base tracking-wide">رئيس رقباء</h5>
                    </div>
                </div>
            </div>

            <!-- قطاع الضباط (Officers) -->
            <div class="bg-[#0a0d12] border border-[#1f2630] rounded-[2rem] p-8 relative overflow-hidden shadow-lg">
                <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-l from-amber-500 to-transparent"></div>
                <div class="flex flex-col items-center mb-8 text-center">
                    <span class="text-4xl mb-2"></span>
                    <h4 class="text-2xl font-black text-white">الضباط والقيادة</h4> 
                    <p class="text-xs text-amber-500/70 font-mono mt-1 tracking-widest">OFFICER RANKS</p>
                </div>

                <div class="flex flex-wrap justify-center gap-4 md:gap-6">
                    <div class="rank-card border border-amber-900/30 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/mulazim.png" alt="ملازم" class="w-16 h-16 object-contain mb-3 drop-shadow-md">
                        <h5 class="text-amber-500/70 font-bold text-sm">ملازم</h5>
                    </div>
                    <div class="rank-card border border-amber-900/50 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/mulazim_awwal.png" alt="ملازم أول" class="w-16 h-16 object-contain mb-3 drop-shadow-md">
                        <h5 class="text-amber-500/80 font-bold text-sm">ملازم أول</h5>
                    </div>
                    <div class="rank-card border border-amber-800/50 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/naqeeb.png" alt="نقيب" class="w-16 h-16 object-contain mb-3 drop-shadow-md">
                        <h5 class="text-amber-500/90 font-bold text-sm">نقيب</h5>
                    </div>
                    <div class="rank-card border border-amber-700/50 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/raed.png" alt="رائد" class="w-16 h-16 object-contain mb-3 drop-shadow-lg">
                        <h5 class="text-amber-500 font-bold text-sm">رائد</h5>
                    </div>
                    <div class="rank-card border border-amber-600/50 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/muqaddam.png" alt="مقدم" class="w-16 h-16 object-contain mb-3 drop-shadow-lg">
                        <h5 class="text-amber-400 font-bold text-sm">مقدم</h5>
                    </div>
                    <div class="rank-card border border-amber-500/50 rounded-2xl p-4 w-32 flex flex-col items-center text-center">
                        <img src="/images/ranks/aqeed.png" alt="عقيد" class="w-16 h-16 object-contain mb-3 drop-shadow-xl">
                        <h5 class="text-amber-300 font-bold text-sm">عقيد</h5>
                    </div>
                    <div class="rank-card border border-amber-400/50 rounded-2xl p-4 w-36 flex flex-col items-center text-center shadow-[0_0_15px_rgba(245,158,11,0.1)]">
                        <img src="/images/ranks/ameed.png" alt="عميد" class="w-16 h-16 object-contain mb-3 drop-shadow-2xl">
                        <h5 class="text-amber-200 font-black text-sm">عميد</h5>
                    </div>
                    <div class="w-full sm:w-auto bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600 border-2 border-yellow-300 rounded-2xl p-6 flex flex-col items-center text-center shadow-[0_0_40px_rgba(245,158,11,0.4)] relative overflow-hidden group">
                        <div class="absolute inset-0 bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <img src="/images/ranks/liwa.png" alt="لواء" class="w-24 h-24 object-contain mb-4 drop-shadow-[0_10px_10px_rgba(0,0,0,0.5)]">
                        <p class="text-amber-900 text-[10px] font-mono font-bold mb-1 uppercase tracking-widest">Supreme Command</p>
                        <h5 class="text-black font-black text-3xl tracking-widest">لواء</h5>
                    </div>
                                        <div class="w-full sm:w-auto bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600 border-2 border-yellow-300 rounded-2xl p-6 flex flex-col items-center text-center shadow-[0_0_40px_rgba(245,158,11,0.4)] relative overflow-hidden group">
                        <div class="absolute inset-0 bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <img src="/images/ranks/fareeq.png" alt="فريق" class="w-24 h-24 object-contain mb-4 drop-shadow-[0_10px_10px_rgba(0,0,0,0.5)]">
                        <p class="text-amber-900 text-[10px] font-mono font-bold mb-1 uppercase tracking-widest">Supreme Command</p>
                        <h5 class="text-black font-black text-3xl tracking-widest">فريق</h5>
                    </div>
                    <div class="w-full sm:w-auto bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600 border-2 border-yellow-300 rounded-2xl p-6 flex flex-col items-center text-center shadow-[0_0_40px_rgba(245,158,11,0.4)] relative overflow-hidden group">
                        <div class="absolute inset-0 bg-white/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <img src="/images/ranks/fareeq_awal.png" alt="فريق أول" class="w-24 h-24 object-contain mb-4 drop-shadow-[0_10px_10px_rgba(0,0,0,0.5)]">
                        <p class="text-amber-900 text-[10px] font-mono font-bold mb-1 uppercase tracking-widest">Supreme Command</p>
                        <h5 class="text-black font-black text-3xl tracking-widest">فريق أول</h5>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. بنك الأسئلة الميدانية (التصميم المنظم والجديد بالكامل - Accordion) -->
        <% 
            const stopsQ = questions.filter(q => q.section === 'stops');
            const negQ = questions.filter(q => q.section === 'neg');
            const opsQ = questions.filter(q => q.section === 'ops');
            const genQ = questions.filter(q => q.section === 'gen');
        %>

        <div class="mt-24">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 mb-10 border-b border-[#1f2630] pb-5">
                <div>
                    <span class="text-blue-500 font-mono text-xs font-bold uppercase tracking-widest">OFFICIAL QUESTION BANK</span>
                    <h3 class="text-3xl font-black text-white tracking-wide mt-1">بنك الأسئلة الميدانية الشامل</h3>
                    <p class="text-sm text-gray-500 mt-2">قاعدة بيانات مقسمة بحسب قطاعات التدريب. اضغط على القطاع لاستعراض الأسئلة.</p>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto items-center">
                    <input type="text" id="searchInput" onkeyup="filterQuestions()" placeholder="🔍 ابحث في جميع القطاعات..." class="search-input sm:w-64">
                    <button onclick="openAddModal()" class="btn !bg-white !text-black hover:!bg-gray-200 whitespace-nowrap !py-2.5 font-bold shadow-[0_0_15px_rgba(255,255,255,0.2)]">
                        ➕ إدراج سؤال جديد
                    </button>
                </div>
            </div>

            <!-- حاوية القطاعات المطوية -->
            <div class="flex flex-col gap-6">
                
                <!-- قطاع الاستيقافات -->
                <div class="q-sector bg-[#080b10] border border-[#1f2630] rounded-2xl overflow-hidden shadow-sm">
                    <button onclick="toggleSector('sector-stops')" class="w-full flex items-center justify-between bg-[#0d1117] hover:bg-[#121820] border-b border-[#1f2630] px-6 py-5 transition-colors group">
                        <div class="flex items-center gap-4 text-right">
                            <span class="text-2xl">🚓</span>
                            <div>
                                <h4 class="text-lg font-black text-teal-400">قطاع الاستيقافات الميدانية</h4>
                                <p class="text-[10px] text-gray-500 font-mono mt-1">STOPS TRAINING SECTOR</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="bg-teal-500/10 text-teal-400 border border-teal-500/30 px-3 py-1 rounded-md text-xs font-bold"><%= stopsQ.length %> أسئلة</span>
                            <svg id="icon-sector-stops" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400 group-hover:text-teal-400 toggle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </button>
                    <div id="sector-stops" class="hidden">
                        <div class="p-6">
                            <% if(stopsQ.length === 0) { %>
                                <p class="text-sm text-gray-600 font-mono text-center py-4">لا توجد أسئلة مدرجة في قطاع الاستيقافات حالياً.</p>
                            <% } else { %>
                                <div class="grid grid-cols-1 gap-3">
                                    <% stopsQ.forEach(q => { %>
                                        <div class="question-line flex flex-col md:flex-row items-center justify-between bg-[#0a0d12] border border-teal-900/30 rounded-xl p-4 gap-4" data-search="<%= q.text %>">
                                            <p class="text-sm font-bold text-gray-300 leading-relaxed flex-1"><%= q.text %></p>
                                            <div class="flex items-center gap-4">
                                                <div class="text-[11px] font-mono text-gray-500">المُضيف: <span class="text-gray-400"><%= q.addedBy %></span></div>
                                                <div class="bg-[#05070a] px-3 py-1 rounded-lg border border-[#1f2630] text-xs font-mono"><span class="text-gray-500">الدرجة:</span> <strong class="text-teal-400"><%= q.maxScore %></strong></div>
                                                <% if(isSupervisor) { %><button onclick="deleteQuestion('<%= q.id %>')" class="text-red-500 hover:text-red-400 bg-red-500/10 p-1.5 rounded-lg transition" title="حذف">✕</button><% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- قطاع التفاوض -->
                <div class="q-sector bg-[#080b10] border border-[#1f2630] rounded-2xl overflow-hidden shadow-sm">
                    <button onclick="toggleSector('sector-neg')" class="w-full flex items-center justify-between bg-[#0d1117] hover:bg-[#121820] border-b border-[#1f2630] px-6 py-5 transition-colors group">
                        <div class="flex items-center gap-4 text-right">
                            <span class="text-2xl">🗣️</span>
                            <div>
                                <h4 class="text-lg font-black text-amber-500">قطاع التفاوض الإستراتيجي</h4>
                                <p class="text-[10px] text-gray-500 font-mono mt-1">NEGOTIATION TRAINING SECTOR</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="bg-amber-500/10 text-amber-500 border border-amber-500/30 px-3 py-1 rounded-md text-xs font-bold"><%= negQ.length %> أسئلة</span>
                            <svg id="icon-sector-neg" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400 group-hover:text-amber-400 toggle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </button>
                    <div id="sector-neg" class="hidden">
                        <div class="p-6">
                            <% if(negQ.length === 0) { %>
                                <p class="text-sm text-gray-600 font-mono text-center py-4">لا توجد أسئلة مدرجة في قطاع التفاوض حالياً.</p>
                            <% } else { %>
                                <div class="grid grid-cols-1 gap-3">
                                    <% negQ.forEach(q => { %>
                                        <div class="question-line flex flex-col md:flex-row items-center justify-between bg-[#0a0d12] border border-amber-900/30 rounded-xl p-4 gap-4" data-search="<%= q.text %>">
                                            <p class="text-sm font-bold text-gray-300 leading-relaxed flex-1"><%= q.text %></p>
                                            <div class="flex items-center gap-4">
                                                <div class="text-[11px] font-mono text-gray-500">المُضيف: <span class="text-gray-400"><%= q.addedBy %></span></div>
                                                <div class="bg-[#05070a] px-3 py-1 rounded-lg border border-[#1f2630] text-xs font-mono"><span class="text-gray-500">الدرجة:</span> <strong class="text-amber-500"><%= q.maxScore %></strong></div>
                                                <% if(isSupervisor) { %><button onclick="deleteQuestion('<%= q.id %>')" class="text-red-500 hover:text-red-400 bg-red-500/10 p-1.5 rounded-lg transition" title="حذف">✕</button><% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- قطاع العمليات -->
                <div class="q-sector bg-[#080b10] border border-[#1f2630] rounded-2xl overflow-hidden shadow-sm">
                    <button onclick="toggleSector('sector-ops')" class="w-full flex items-center justify-between bg-[#0d1117] hover:bg-[#121820] border-b border-[#1f2630] px-6 py-5 transition-colors group">
                        <div class="flex items-center gap-4 text-right">
                            <span class="text-2xl">⚙️</span>
                            <div>
                                <h4 class="text-lg font-black text-purple-400">قطاع إدارة العمليات</h4>
                                <p class="text-[10px] text-gray-500 font-mono mt-1">OPERATIONS TRAINING SECTOR</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="bg-purple-500/10 text-purple-400 border border-purple-500/30 px-3 py-1 rounded-md text-xs font-bold"><%= opsQ.length %> أسئلة</span>
                            <svg id="icon-sector-ops" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400 group-hover:text-purple-400 toggle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </button>
                    <div id="sector-ops" class="hidden">
                        <div class="p-6">
                            <% if(opsQ.length === 0) { %>
                                <p class="text-sm text-gray-600 font-mono text-center py-4">لا توجد أسئلة مدرجة في قطاع العمليات حالياً.</p>
                            <% } else { %>
                                <div class="grid grid-cols-1 gap-3">
                                    <% opsQ.forEach(q => { %>
                                        <div class="question-line flex flex-col md:flex-row items-center justify-between bg-[#0a0d12] border border-purple-900/30 rounded-xl p-4 gap-4" data-search="<%= q.text %>">
                                            <p class="text-sm font-bold text-gray-300 leading-relaxed flex-1"><%= q.text %></p>
                                            <div class="flex items-center gap-4">
                                                <div class="text-[11px] font-mono text-gray-500">المُضيف: <span class="text-gray-400"><%= q.addedBy %></span></div>
                                                <div class="bg-[#05070a] px-3 py-1 rounded-lg border border-[#1f2630] text-xs font-mono"><span class="text-gray-500">الدرجة:</span> <strong class="text-purple-400"><%= q.maxScore %></strong></div>
                                                <% if(isSupervisor) { %><button onclick="deleteQuestion('<%= q.id %>')" class="text-red-500 hover:text-red-400 bg-red-500/10 p-1.5 rounded-lg transition" title="حذف">✕</button><% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- قطاع الأنظمة العامة -->
                <div class="q-sector bg-[#080b10] border border-[#1f2630] rounded-2xl overflow-hidden shadow-sm">
                    <button onclick="toggleSector('sector-gen')" class="w-full flex items-center justify-between bg-[#0d1117] hover:bg-[#121820] border-b border-[#1f2630] px-6 py-5 transition-colors group">
                        <div class="flex items-center gap-4 text-right">
                            <span class="text-2xl">❓</span>
                            <div>
                                <h4 class="text-lg font-black text-blue-400">قطاع الأنظمة العامة</h4>
                                <p class="text-[10px] text-gray-500 font-mono mt-1">GENERAL SYSTEMS SECTOR</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <span class="bg-blue-500/10 text-blue-400 border border-blue-500/30 px-3 py-1 rounded-md text-xs font-bold"><%= genQ.length %> أسئلة</span>
                            <svg id="icon-sector-gen" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400 group-hover:text-blue-400 toggle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </button>
                    <div id="sector-gen" class="hidden">
                        <div class="p-6">
                            <% if(genQ.length === 0) { %>
                                <p class="text-sm text-gray-600 font-mono text-center py-4">لا توجد أسئلة مدرجة في قطاع الأنظمة العامة حالياً.</p>
                            <% } else { %>
                                <div class="grid grid-cols-1 gap-3">
                                    <% genQ.forEach(q => { %>
                                        <div class="question-line flex flex-col md:flex-row items-center justify-between bg-[#0a0d12] border border-blue-900/30 rounded-xl p-4 gap-4" data-search="<%= q.text %>">
                                            <p class="text-sm font-bold text-gray-300 leading-relaxed flex-1"><%= q.text %></p>
                                            <div class="flex items-center gap-4">
                                                <div class="text-[11px] font-mono text-gray-500">المُضيف: <span class="text-gray-400"><%= q.addedBy %></span></div>
                                                <div class="bg-[#05070a] px-3 py-1 rounded-lg border border-[#1f2630] text-xs font-mono"><span class="text-gray-500">الدرجة:</span> <strong class="text-blue-400"><%= q.maxScore %></strong></div>
                                                <% if(isSupervisor) { %><button onclick="deleteQuestion('<%= q.id %>')" class="text-red-500 hover:text-red-400 bg-red-500/10 p-1.5 rounded-lg transition" title="حذف">✕</button><% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- النافذة المنبثقة لإضافة الأسئلة (بدون تغيير لضمان البرمجة) -->
    <div id="addQuestionModal" class="fixed inset-0 z-[70] hidden items-center justify-center bg-black/90 backdrop-blur-md p-4">
        <div class="bg-[#0e1218] border border-blue-500/40 w-full max-w-md rounded-2xl shadow-2xl p-6 animate-modal">
            <h3 class="text-xl font-black text-white mb-2">➕ إضافة سؤال تخصصي</h3>
            <p class="text-xs text-gray-400 mb-6">سيتم تسجيل السؤال في قاعدة البيانات ضمن القطاع المحدد.</p>
            
            <div class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-gray-300">القطاع المستهدف:</label>
                    <select id="qSection" class="search-input mt-1 w-full bg-[#12171f]">
                        <% if(user.permissions.canGradeStops || isSupervisor) { %><option value="stops">🚓 قطاع الاستيقافات</option><% } %>
                        <% if(user.permissions.canGradeNeg || isSupervisor) { %><option value="neg">🗣️ قطاع التفاوض</option><% } %>
                        <% if(user.permissions.canGradeOps || isSupervisor) { %><option value="ops">⚙️ قطاع العمليات</option><% } %>
                        <% if(user.permissions.canGradeGen || isSupervisor) { %><option value="gen">❓ قطاع الأنظمة العامة</option><% } %>
                    </select>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-300">نص السؤال:</label>
                    <textarea id="qText" class="search-input mt-1 w-full h-24 p-3 resize-none" placeholder="اكتب نص السؤال العسكري هنا..."></textarea>
                </div>
                <div>
                    <label class="text-xs font-bold text-gray-300">الدرجة المستحقة:</label>
                    <input type="number" id="qScore" class="search-input mt-1 w-full" placeholder="مثال: 2" min="1">
                </div>
            </div>

            <div class="flex gap-3 mt-8">
                <button onclick="closeModal()" class="btn bg-[#1a2029] text-gray-400 hover:text-white border border-[#222b38]">إلغاء</button>
                <button onclick="submitNewQuestion()" id="confirmAddBtn" class="btn !bg-white !text-black hover:!bg-gray-200">✔ اعتماد الإدراج</button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script>
        // دالة طي وفتح القطاعات
        function toggleSector(sectorId) {
            const content = document.getElementById(sectorId);
            const button = content.previousElementSibling;
            
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                button.classList.add('is-open');
            } else {
                content.classList.add('hidden');
                button.classList.remove('is-open');
            }
        }

        // فلترة الأسئلة (تبحث في كل الأقسام وتفتح القسم تلقائياً إذا لقت سؤال)
        function filterQuestions() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const lines = document.querySelectorAll('.question-line');
            
            // فتح جميع القطاعات أثناء البحث للتسهيل
            if(input.length > 0) {
                document.querySelectorAll('.q-sector > div[id^="sector-"]').forEach(div => div.classList.remove('hidden'));
                document.querySelectorAll('.q-sector > button').forEach(btn => btn.classList.add('is-open'));
            }

            lines.forEach(line => {
                line.style.display = line.getAttribute('data-search').toLowerCase().includes(input) ? 'flex' : 'none';
            });
        }

        function openAddModal() {
            document.getElementById('qText').value = '';
            document.getElementById('qScore').value = '';
            document.getElementById('addQuestionModal').classList.remove('hidden');
            document.getElementById('addQuestionModal').classList.add('flex');
        }

        function closeModal() {
            document.getElementById('addQuestionModal').classList.add('hidden');
            document.getElementById('addQuestionModal').classList.remove('flex');
        }

        async function submitNewQuestion() {
            const section = document.getElementById('qSection').value;
            const text = document.getElementById('qText').value.trim();
            const maxScore = document.getElementById('qScore').value.trim();

            if (!text || !maxScore) {
                alert("يرجى تعبئة نص السؤال والدرجة المستحقة أولاً!");
                return;
            }

            const btn = document.getElementById('confirmAddBtn');
            btn.innerText = "⏳ جاري الإدراج..."; btn.disabled = true;

            try {
                const response = await fetch('/api/guide/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ section, text, maxScore })
                });
                const result = await response.json();
                if (result.success) location.reload();
                else { alert('⚠️ خطأ: ' + result.error); btn.disabled = false; btn.innerText = "✔ اعتماد الإدراج"; }
            } catch (err) { alert('⚠️ تعذر الاتصال بالسيرفر.'); btn.disabled = false; }
        }

        async function deleteQuestion(id) {
            if (confirm("🚨 تحذير: هل أنت متأكد من حذف هذا السؤال نهائياً من قاعدة البيانات؟")) {
                const response = await fetch('/api/guide/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                const result = await response.json();
                if (result.success) location.reload();
                else alert('⚠️ خطأ: ' + result.error);
            }
        }
    </script>
</body>
</html>